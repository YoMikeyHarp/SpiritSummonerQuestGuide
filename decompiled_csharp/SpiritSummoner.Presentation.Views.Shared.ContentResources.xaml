                <GradientStop Color="#B6B6B6"
                              Offset="0.5"/>
                <GradientStop Color="#B6B6B6"
                              Offset="0.75"/>
                <GradientStop Color="#CBCBCB"
                              Offset="1.0"/>
        </LinearGradientBrush>

        <Shadow x:Key="LabelBlackShadow"
                Brush="Black"
                Offset="0,1"
                Radius="3">
        </Shadow>

        <Shadow x:Key="LabelWhiteShadow"
                Brush="White"
                Offset="1,1"
                Radius="5">
        </Shadow>

        <Shadow x:Key="LabelRedShadow"
                Offset="1,-1"
                Brush="#C8570C"
                Opacity="0.8"
                Radius="5">
        </Shadow>

        <Shadow x:Key="GoldenShadow"
                Offset="1,-1"
                Brush="DarkGoldenrod"
                Opacity="0.7">

        </Shadow>

        <Shadow x:Key="ImageShadow"
                Offset="1,-1"
                Brush="White"
                Opacity="1"
                Radius="0.5">
        </Shadow>

        <Shadow x:Key="HPbarShadow"
                Brush="#4027AE60"
                Offset="2,2"
                Radius="3">
        </Shadow>

        <!-- Spirit Card New - Red Button Gradient (for Sell) -->
        <LinearGradientBrush x:Key="RedButtonGradient" StartPoint="0,1" EndPoint="0,0">
