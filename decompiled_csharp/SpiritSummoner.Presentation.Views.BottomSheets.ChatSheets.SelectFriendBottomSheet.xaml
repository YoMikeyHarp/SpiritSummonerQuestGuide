<?xml version="1.0" encoding="utf-8" ?>
<the49:BottomSheet xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                   xmlns:the49="https://schemas.the49.com/dotnet/2023/maui"
                   xmlns:vm="clr-namespace:SpiritSummoner.Presentation.ViewModels.BottomSheet"
                   xmlns:chat="clr-namespace:SpiritSummoner.Presentation.ViewModels.Chat"
                   xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
                   xmlns:outline="clr-namespace:SpiritSummoner.Presentation.ViewModels.Shared"
                   HasBackdrop="True"
                   IsCancelable="true"
                   Dismissed="BottomSheet_Dismissed"
                   BackgroundColor="Transparent"
                   x:Class="SpiritSummoner.Presentation.Views.BottomSheets.ChatSheets.SelectFriendBottomSheet"
                   x:DataType="vm:SelectFriendSheetViewModel">

    <Grid VerticalOptions="{OnPlatform Android=End}">
        <Border Stroke="Transparent"
                Background="{StaticResource TanGradient}"
                StrokeShape="RoundRectangle 8"
                Padding="16"
                VerticalOptions="End">

            <Grid RowDefinitions="Auto,*"
                  RowSpacing="12">

                <outline:OutlinedLabel Grid.Row="0"
                                       Text="New Message"
                                       FontFamily="PoppinsBold"
                                       FontSize="20"
                                       TextColor="#2E4A0F"
                                       HasShadow="True"
                                       ShadowColor="#29000040"
                                       ShadowBlur="2"
                                       ShadowOffsetY="2"/>

                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding Friends}"
                                SelectionMode="None"
                                VerticalScrollBarVisibility="Never"
                                MaximumHeightRequest="400">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="chat:ChatPlayerModel">
                            <Border BackgroundColor="#EDF8EA"
                                    StrokeShape="RoundRectangle 8"
                                    Stroke="#32000040"
                                    StrokeThickness="1"
                                    Padding="12,10">
                                <Border.Behaviors>
                                    <toolkit:TouchBehavior DefaultAnimationDuration="150"
                                                           DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                                                           PressedOpacity="0.6"
                                                           PressedScale="0.97"/>
                                </Border.Behaviors>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding x:DataType='vm:SelectFriendSheetViewModel', Source={RelativeSource AncestorType={x:Type vm:SelectFriendSheetViewModel}}, Path=SelectFriendCommand}"
                                                          CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12">

                                    <!-- Avatar with online dot -->
                                    <Grid Grid.Column="0"
                                          WidthRequest="44"
                                          HeightRequest="44">
                                        <Ellipse Fill="#4F88FA"
                                                 Stroke="#80000000"
                                                 StrokeThickness="1"
                                                 WidthRequest="44"
                                                 HeightRequest="44"/>
                                        <Border WidthRequest="12"
                                                HeightRequest="12"
                                                StrokeShape="RoundRectangle 6"
                                                BackgroundColor="{Binding OnlineStatusColor}"
                                                Stroke="White"
                                                StrokeThickness="2"
                                                HorizontalOptions="End"
                                                VerticalOptions="End"/>
                                    </Grid>

                                    <!-- Name -->
                                    <Label Grid.Column="1"
                                           Text="{Binding PlayerName}"
                                           FontFamily="PoppinsSemiBold"
                                           FontSize="15"
                                           TextColor="#1A1A1A"
                                           VerticalOptions="Center"
                                           LineBreakMode="TailTruncation"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.EmptyView>
                        <Label Text="No friends yet"
                               FontFamily="Poppins"
                               FontSize="14"
                               TextColor="#80000000"
                               HorizontalOptions="Center"
                               Margin="0,16"/>
                    </CollectionView.EmptyView>
                </CollectionView>

            </Grid>
        </Border>
    </Grid>

</the49:BottomSheet>
