<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:vm="clr-namespace:SpiritSummoner.Presentation.ViewModels.Popups"
               xmlns:cnv="clr-namespace:SpiritSummoner.Presentation.Converters"
               x:Class="SpiritSummoner.Presentation.Views.Popups.GuildPopups.GuildSearchFilterPopup"
               x:DataType="vm:GuildSearchFilterPopupViewModel"
               CanBeDismissedByTappingOutsideOfPopup="True">

    <toolkit:Popup.Resources>
        <cnv:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </toolkit:Popup.Resources>

    <!-- Main Container -->
    <Border StrokeShape="RoundRectangle 20"
            Stroke="White"
            StrokeThickness="2"
            Padding="0"
            WidthRequest="360">

        <Border.Background>
            <RadialGradientBrush Center="0.5,0.5"
                                 Radius="0.6">
                <GradientStop Color="#D1EAFB"
                              Offset="0"/>
                <GradientStop Color="#66ABE7"
                              Offset="1"/>
            </RadialGradientBrush>
        </Border.Background>

        <Border.Shadow>
            <Shadow Brush="#80000000"
                    Offset="0,10"
                    Opacity="0.8"
                    Radius="20"/>
        </Border.Shadow>

        <Grid RowDefinitions="Auto,*,Auto"
              Padding="15,10">

            <!-- Header with Title and Close Button -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  Margin="0,5,0,15">

                <!-- Title -->
                <Label Grid.Column="0"
                       Text="SEARCH FILTERS"
                       FontSize="Large" 
                       FontFamily="PoppinsSemiBold"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="Black"/>

                <!-- Close Button -->
                <ImageButton Grid.Column="1"
                             Source="{mi:FontAwesomeSolid Icon=Xmark, IconColor=Black}"
                             BackgroundColor="Transparent"
                             BorderWidth="0"
                             Clicked="OnCloseClicked"
                             WidthRequest="40"
                             HeightRequest="40"/>
            </Grid>

            <!-- Filter Options -->
                <VerticalStackLayout Spacing="15" Grid.Row="1">

                    <!-- Guild Type Section -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Guild Type"
                               FontSize="Medium"
                               FontFamily="PoppinsSemiBold"
                               FontAttributes="Bold"
                               TextColor="Black"/>

                        <Grid ColumnDefinitions="*,*,*"
                              ColumnSpacing="8">
                            <!-- All Button -->
                            <Border Grid.Column="0"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{Binding GuildTypeFilter, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#27AE60,#5C82A9'}"
                                    Padding="8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetGuildTypeCommand}"
                                                          CommandParameter="all"/>
                                </Border.GestureRecognizers>
                                <Border.Behaviors>
                                    <toolkit:TouchBehavior
                                        DefaultAnimationDuration="200"
                                        DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                                        PressedOpacity="0.7"
                                        PressedScale="0.95"/>
                                </Border.Behaviors>
                                <Label Text="All"
                                       FontSize="Small"
                                       FontFamily="PoppinsSemiBold"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <!-- Public Button -->
                            <Border Grid.Column="1"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{Binding GuildTypeFilter, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#27AE60,#5C82A9'}"
                                    Padding="8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetGuildTypeCommand}"
                                                          CommandParameter="public"/>
                                </Border.GestureRecognizers>
                                <Border.Behaviors>
                                    <toolkit:TouchBehavior
                                        DefaultAnimationDuration="200"
                                        DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                                        PressedOpacity="0.7"
                                        PressedScale="0.95"/>
                                </Border.Behaviors>
                                <Label Text="Public"
                                       FontSize="Small"
                                       FontFamily="PoppinsSemiBold"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <!-- Invite Button -->
                            <Border Grid.Column="2"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{Binding GuildTypeFilter, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#27AE60,#5C82A9'}"
                                    Padding="8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetGuildTypeCommand}"
                                                          CommandParameter="invite"/>
                                </Border.GestureRecognizers>
                                <Border.Behaviors>
                                    <toolkit:TouchBehavior
                                        DefaultAnimationDuration="200"
                                        DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                                        PressedOpacity="0.7"
                                        PressedScale="0.95"/>
                                </Border.Behaviors>
                                <Label Text="Invite"
                                       FontSize="Small"
                                       FontFamily="PoppinsSemiBold"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Members Section -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Members"
                               FontSize="Medium"
                               FontFamily="PoppinsSemiBold"
                               FontAttributes="Bold"
                               TextColor="Black"/>

                        <Grid ColumnDefinitions="*,Auto,*"
                              ColumnSpacing="8">
                            <Entry Grid.Column="0"
                                   Text="{Binding MinMembers}"
                                   Placeholder="Min"
                                   Keyboard="Numeric"
                                   BackgroundColor="White"
                                   TextColor="Black"
                                   PlaceholderColor="Gray"
                                   FontFamily="PoppinsSemiBold"
                                   HorizontalTextAlignment="Center"/>

                            <Label Grid.Column="1"
                                   Text="-"
                                   FontSize="Large"
                                   FontAttributes="Bold"
                                   TextColor="Black"
                                   VerticalOptions="Center"/>

                            <Entry Grid.Column="2"
                                   Text="{Binding MaxMembers}"
                                   Placeholder="Max"
                                   Keyboard="Numeric"
                                   BackgroundColor="White"
                                   TextColor="Black"
                                   PlaceholderColor="Gray"
                                   FontFamily="PoppinsSemiBold"
                                   HorizontalTextAlignment="Center"/>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Trophies Section -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Trophies"
                               FontSize="Medium"
                               FontFamily="PoppinsSemiBold"
                               FontAttributes="Bold"
                               TextColor="Black"/>

                        <Grid ColumnDefinitions="*,Auto,*"
                              ColumnSpacing="8">
                            <Entry Grid.Column="0"
                                   Text="{Binding MinTrophies}"
                                   Placeholder="Min"
                                   Keyboard="Numeric"
                                   BackgroundColor="White"
                                   TextColor="Black"
                                   PlaceholderColor="Gray"
                                   FontFamily="PoppinsSemiBold"
                                   HorizontalTextAlignment="Center"/>

                            <Label Grid.Column="1"
                                   Text="-"
                                   FontSize="Large"
                                   FontAttributes="Bold"
                                   TextColor="Black"
                                   VerticalOptions="Center"/>

                            <Entry Grid.Column="2"
                                   Text="{Binding MaxTrophies}"
                                   Placeholder="Max"
                                   Keyboard="Numeric"
                                   BackgroundColor="White"
                                   TextColor="Black"
                                   PlaceholderColor="Gray"
                                   FontFamily="PoppinsSemiBold"
                                   HorizontalTextAlignment="Center"/>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Level Section -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Level"
                               FontSize="Medium"
                               FontFamily="PoppinsSemiBold"
                               FontAttributes="Bold"
                               TextColor="Black"/>

                        <Grid ColumnDefinitions="*,Auto,*"
                              ColumnSpacing="8">
                            <Entry Grid.Column="0"
                                   Text="{Binding MinLevel}"
                                   Placeholder="Min"
                                   Keyboard="Numeric"
                                   BackgroundColor="White"
                                   TextColor="Black"
                                   PlaceholderColor="Gray"
                                   FontFamily="PoppinsSemiBold"
                                   HorizontalTextAlignment="Center"/>

                            <Label Grid.Column="1"
                                   Text="-"
                                   FontSize="Large"
                                   FontAttributes="Bold"
                                   TextColor="Black"
                                   VerticalOptions="Center"/>

                            <Entry Grid.Column="2"
                                   Text="{Binding MaxLevel}"
                                   Placeholder="Max"
                                   Keyboard="Numeric"
                                   BackgroundColor="White"
                                   TextColor="Black"
                                   PlaceholderColor="Gray"
                                   FontFamily="PoppinsSemiBold"
                                   HorizontalTextAlignment="Center"/>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Only Joinable Toggle -->
                    <Border StrokeShape="RoundRectangle 8"
                            BackgroundColor="#5C82A9"
                            Padding="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   Text="Show Only Joinable"
                                   FontSize="Medium"
                                   FontFamily="PoppinsSemiBold"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalOptions="Center"/>

                            <Switch Grid.Column="1"
                                    IsToggled="{Binding ShowOnlyJoinable}"
                                    OnColor="#27AE60"
                                    ThumbColor="White"/>
                        </Grid>
                    </Border>

                </VerticalStackLayout>


            <!-- Action Buttons -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="10"
                  Margin="0,15,0,5">

                <!-- Clear Button -->
                <Button Grid.Column="0"
                        Text="CLEAR"
                        BackgroundColor="#E74C3C"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontFamily="PoppinsSemiBold"
                        CornerRadius="8"
                        HeightRequest="45"
                        Command="{Binding ClearFiltersCommand}">
                    <Button.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,2"
                                Radius="4"
                                Opacity="0.3"/>
                    </Button.Shadow>
                </Button>

                <!-- Apply Button -->
                <Button Grid.Column="1"
                        Text="APPLY"
                        BackgroundColor="#27AE60"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontFamily="PoppinsSemiBold"
                        CornerRadius="8"
                        HeightRequest="45"
                        Command="{Binding ApplyFiltersMethodCommand}"
                        Clicked="OnApplyClicked">
                    <Button.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,2"
                                Radius="4"
                                Opacity="0.3"/>
                    </Button.Shadow>
                </Button>
            </Grid>

        </Grid>
    </Border>
</toolkit:Popup>
