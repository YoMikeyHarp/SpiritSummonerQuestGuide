        <LinearGradientBrush x:Key="LevelBadgeGreenGradient" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#9AE589" Offset="0.05"/>
                <GradientStop Color="#9CDF86" Offset="0.53"/>
                <GradientStop Color="#9EDA84" Offset="1.0"/>
        </LinearGradientBrush>

