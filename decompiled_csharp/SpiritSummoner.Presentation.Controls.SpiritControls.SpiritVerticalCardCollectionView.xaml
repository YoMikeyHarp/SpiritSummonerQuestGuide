<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="SpiritSummoner.Presentation.Controls.SpiritControls.SpiritVerticalCardCollectionView"
             xmlns:vm="clr-namespace:SpiritSummoner.Presentation.ViewModels.Spirits"
             xmlns:cnv="clr-namespace:SpiritSummoner.Presentation.Converters"
             xmlns:outline="clr-namespace:SpiritSummoner.Presentation.ViewModels.Shared"
             x:DataType="vm:SpiritCardViewModel">

    <ContentView.Resources>
        <cnv:BackgroundImageConverter x:Key="BackgroundImageConverter"/>
        <cnv:NameToImageConverter x:Key="NameToImageConverter"/>
        <cnv:StringToBoolConverter x:Key="StringToBoolConverter"/>
        <cnv:TypeToColorConverter x:Key="TypeToColorConverter"/>
        <cnv:CardBackgroundImageConverter x:Key="CardBackgroundImageConverter"/>
    </ContentView.Resources>

    <!-- Main Card Container -->
    <Grid IsVisible="{Binding HasSpirit}">

        <!-- Card Border -->
        <Border Padding="10"
                StrokeShape="RoundRectangle 6"
                BackgroundColor="{Binding Model.Type1, Converter={StaticResource TypeToColorConverter}}"
                Stroke="#40000000" 
                StrokeThickness="3">

            <!-- Default Content Grid -->
            <Grid x:Name="DefaultContent" Padding="0" RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="27"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="72"/>
                </Grid.RowDefinitions>

                <!-- Type Background Image -->
                <Image Grid.Row="1"
                       Grid.RowSpan="2"
                       Source="{Binding Model.Type1,Converter={StaticResource CardBackgroundImageConverter}}"
                       Aspect="AspectFill"/>
                
                <Image Grid.RowSpan="2" Grid.Row="1"
                       Source="icon_bubbles_stars.png"
                       Aspect="AspectFit"/>

                <!-- Info Bar (Top) -->
                <Border Grid.Row="0"
                        Background="{StaticResource SpiritsForegroundButton}"
                        StrokeShape="RoundRectangle 2,2,0,0"
                        Stroke="#4B000040"
                        StrokeThickness="1"
                        Padding="4,0">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Opacity="0.25" Radius="2"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*,Auto">
                        <!-- Spirit Name -->
                        <outline:OutlinedLabel Grid.Column="0"
                                               Text="{Binding Model.Nickname}"
                                               FontFamily="PoppinsSemiBold"
                                               FontSize="14"
                                               TextColor="#EDF8EA"
                                               HorizontalOptions="Start"
                                               VerticalOptions="Center"
                                               StrokeColor="#2E4A0F"
                                               StrokeWidth="2"
                                               HasShadow="True"
                                               ShadowColor="#40000000"
                                               ShadowBlur="1"
                                               ShadowOffsetY="1"/>

                        <!-- Type Icons -->
                        <HorizontalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                            <Image Source="{Binding Model.Type1, Converter={StaticResource NameToImageConverter}}"
                                   HeightRequest="20" WidthRequest="20">
                                <Image.Shadow>
                                    <Shadow Brush="Black" Offset="0,1" Opacity="0.25" Radius="1"/>
                                </Image.Shadow>
                            </Image>
                            <Image Source="{Binding Model.Type2, Converter={StaticResource NameToImageConverter}}"
                                   HeightRequest="20" WidthRequest="20"
                                   IsVisible="{Binding Model.HasType2,FallbackValue=false}">
                                <Image.Shadow>
                                    <Shadow Brush="Black" Offset="0,1" Opacity="0.25" Radius="1"/>
                                </Image.Shadow>
                            </Image>
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <!-- Spirit Image (Center Area) -->
                <Image Grid.Row="1"
                       Source="{Binding Model.Image}"
                       HeightRequest="260"
                       WidthRequest="179"
                       Scale="1"
                       Aspect="AspectFit"
                       TranslationX="5"/>

                <!-- Level Badge (Bottom-Left Overlay) -->
                <Grid Grid.Row="1"
                      VerticalOptions="Start"
                      HorizontalOptions="Start"
                      WidthRequest="49"
                      HeightRequest="49">
                    <!-- Outer Circle -->
                    <Ellipse Fill="{StaticResource LevelBadgeGreenGradient}"
                             Stroke="#588049"
                             HorizontalOptions="Start"
                             StrokeThickness="1"
                             WidthRequest="49"
                             HeightRequest="49">
                        <Ellipse.Shadow>
                            <Shadow Brush="Black"
                                    Offset="0,1"
                                    Radius="1"
                                    Opacity="0.25"/>
                        </Ellipse.Shadow>
                    </Ellipse>

                    <!-- Inner Circle -->
                    <Ellipse WidthRequest="41"
                             HeightRequest="41"
                             Fill="{StaticResource LevelBadgeBlueGradient}"
                             Stroke="#4B000040"
                             StrokeThickness="1"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"/>

                    <!-- Rank Label -->
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         TranslationY="1"
                                         Spacing="-2">

                        <outline:OutlinedLabel
                            Text="LVL"
                            FontSize="9"
                            FontFamily="PoppinsSemiBold"
                            TextColor="#FFE368"
                            StrokeColor="#BA7412"
                            StrokeWidth="1.75"
                            HorizontalOptions="Center"
                            HasShadow="True"
                            ShadowOffsetX="0"
                            ShadowOffsetY="1"
                            ShadowBlur="1"
                            ShadowSpread="0"
                            ShadowColor="#40000000"/>

                        <outline:OutlinedLabel
                            Text="{Binding Model.Level}"
                            FontSize="15"
                            FontFamily="Bungee"
                            TextColor="#C96D1E"
                            StrokeColor="#EDF8EA"
                            StrokeWidth="4"
                            HorizontalOptions="Center"/>

                    </VerticalStackLayout>
                </Grid>

                <!-- Gear/HeldItem Slots (Left Side) -->
                <Grid Grid.Row="1"
                      RowDefinitions="Auto,Auto"
                      HorizontalOptions="Start"
                      VerticalOptions="End"
                      RowSpacing="3"
                      Padding="5">

                    <!-- Held item Slot -->
                    <Ellipse Fill="{StaticResource SpiritsForegroundButton}"
                             Grid.Row="0"
                             Stroke="#4B000040"
                             StrokeThickness="0.5"
                             WidthRequest="35"
                             HeightRequest="35"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Opacity="0.75">
                        <Ellipse.Shadow>
                            <Shadow Brush="Black"
                                    Offset="0,1"
                                    Radius="1"
                                    Opacity="0.5"/>
                        </Ellipse.Shadow>
                    </Ellipse>

                    <Image Source="{Binding HeldItem.Icon}"
                           HeightRequest="24"
                           WidthRequest="24"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           IsVisible="{Binding HeldItem.Id,Converter={StaticResource StringToBoolConverter},FallbackValue=false}">
                        <Image.Shadow>
                            <Shadow Brush="Black"
                                    Offset="0,0.6"
                                    Opacity="0.25"
                                    Radius="0.6"/>
                        </Image.Shadow>
                    </Image>

                    <!-- Gear Slot -->
                    <Ellipse Fill="{StaticResource SpiritsForegroundButton}"
                             Stroke="#4B000040"
                             Grid.Row="1"
                             StrokeThickness="0.5"
                             WidthRequest="35"
                             HeightRequest="35"
                             HorizontalOptions="Center"
                             Opacity="0.75"
                             VerticalOptions="Center"
                             IsVisible="true">
                        <Ellipse.Shadow>
                            <Shadow Brush="Black"
                                    Offset="0,1"
                                    Radius="1"
                                    Opacity="0.5"/>
                        </Ellipse.Shadow>
                    </Ellipse>

                    <Image Source="icon_gear.png"
                           HeightRequest="24"
                           Grid.Row="1"
                           WidthRequest="24"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           IsVisible="{Binding HasGear}">
                        <Image.Shadow>
                            <Shadow Brush="Black"
                                    Offset="0,0.6"
                                    Opacity="0.25"
                                    Radius="0.6"/>
                        </Image.Shadow>
                    </Image>

                </Grid>

                <!-- Talent Section (Bottom) -->
                <Border Grid.Row="2"
                        Background="{StaticResource SpiritsForegroundButton}"
                        StrokeShape="RoundRectangle 0,0,2,2"
                        Stroke="#4B000040"
                        StrokeThickness="1"
                        Padding="6,4">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Opacity="0.25" Radius="2"/>
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto,*">
                        <!-- Talent Header -->
                        <HorizontalStackLayout Grid.Row="0" Spacing="5">
                            <!-- Talent Label Badge -->
                            <Border BackgroundColor="{Binding Model.Type1,Converter={StaticResource TypeToColorConverter}}"
                                    StrokeShape="RoundRectangle 1"
                                    Stroke="#000000"
                                    StrokeThickness="0.2"
                                    Padding="4,1"
                                    HeightRequest="15"
                                    VerticalOptions="Center">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,1" Opacity="0.25" Radius="1"/>
                                </Border.Shadow>
                                <outline:OutlinedLabel Text="Talent"
                                                       FontFamily="PoppinsItalic"
                                                       FontSize="8"
                                                       TextColor="#EDF8EA"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="Center"
                                                       StrokeColor="#000000"
                                                       StrokeWidth="1.5"
                                                       HasShadow="True"
                                                       ShadowColor="#40000000"
                                                       ShadowBlur="1"
                                                       ShadowOffsetY="1"/>
                            </Border>
                            <!-- Talent Name -->
                            <outline:OutlinedLabel Text="{Binding Talent.Name,FallbackValue=''}"
                                                   FontFamily="PoppinsBold"
                                                   FontSize="10"
                                                   VerticalOptions="Center"
                                                   TextColor="#EDF8EA"
                                                   StrokeColor="#000000"
                                                   StrokeWidth="1"
                                                   HasShadow="True"
                                                   ShadowColor="#40000000"
                                                   ShadowBlur="1"
                                                   ShadowOffsetY="1"/>
                        </HorizontalStackLayout>
                        <!-- Talent Description (placeholder) -->
                        <Label Grid.Row="1"
                               FontFamily="PoppinsMedium"
                               FontSize="8"
                               TextColor="#000000"
                               LineBreakMode="WordWrap"
                               MaxLines="3"
                               Text="{Binding Talent.Description}"
                               Margin="0,2,0,0">
                            <Label.Shadow>
                                <Shadow Brush="#EDF8EA"
                                        Offset="0,1"
                                        Opacity="0.5"
                                        Radius="1"/>
                            </Label.Shadow>
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding Talent.Description,FallbackValue=''}"
                                             Value="">
                                        <Setter Property="Text"
                                                Value="No talent set."/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Grid>
                </Border>

                <!-- Tap Gesture for Card -->
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCardTapped"/>
                </Grid.GestureRecognizers>
                <Grid.Behaviors>
                    <toolkit:TouchBehavior
                        DefaultAnimationDuration="150"
                        PressedOpacity="0.9"
                        PressedScale="0.9"
                        LongPressCompleted="OnCardLongPressed"/>
                </Grid.Behaviors>
            </Grid>
        </Border>

        <!-- Options Overlay -->
        <Border x:Name="OptionsOverlay"
                IsVisible="False"
                StrokeShape="RoundRectangle 6"
                BackgroundColor="{Binding Model.Type1, Converter={StaticResource TypeToColorConverter}}"
                Stroke="Black"
                StrokeThickness="1"
                Padding="8">

            <Grid RowDefinitions="*,*,*,*,*" RowSpacing="4"
                  Padding="5">

                <!-- Background tap area to close overlay (behind buttons) -->
                <BoxView Grid.RowSpan="5"
                         BackgroundColor="{Binding Model.Type1, Converter={StaticResource TypeToColorConverter}}"
                         InputTransparent="False">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOptionsBackgroundTapped"/>
                    </BoxView.GestureRecognizers>
                    <BoxView.Behaviors>
                        <toolkit:TouchBehavior
                            LongPressCompleted="OnOptionsLongPressed"/>
                    </BoxView.Behaviors>
                </BoxView>

                <!-- Partner Button -->
                <Border Grid.Row="0"
                        StrokeShape="RoundRectangle 2"
                        Stroke="#40000000"
                        StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Opacity="0.25" Radius="2"/>
                    </Border.Shadow>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0.5,1" EndPoint="0.5,0">
                            <GradientStop Offset="0" Color="#E99F6A" />
                            <GradientStop Offset="0.25" Color="#D6680F" />
                            <GradientStop Offset="0.75" Color="#D6680F" />
                            <GradientStop Offset="1" Color="#B2590A" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            DefaultAnimationDuration="150"
                            PressedOpacity="0.8"
                            PressedScale="0.97"
                            TouchGestureCompleted="OnPartnerTapped"
                            LongPressCompleted="OnOptionsLongPressed"/>
                    </Border.Behaviors>
                    <outline:OutlinedLabel Text="PARTNER"
                                           FontFamily="PoppinsBlack"
                                           FontSize="18"
                                           TextColor="#EDF8EA"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           StrokeColor="#40000000"
                                           StrokeWidth="2"
                                           HasShadow="True"
                                           ShadowColor="#40000000"
                                           ShadowBlur="2"
                                           ShadowOffsetY="2">
                                    <outline:OutlinedLabel.Triggers>
                                        <DataTrigger TargetType="outline:OutlinedLabel"
                                                     Binding="{Binding IsPartnerSpirit}"
                                                     Value="True">
                                                <Setter Property="IsEnabled"
                                                        Value="false"/>
                                        </DataTrigger>
                                    </outline:OutlinedLabel.Triggers>
                    </outline:OutlinedLabel>
                </Border>

                <!-- Favorite Button -->
                <Border Grid.Row="1"
                        Background="{StaticResource GreenButtonGradient}"
                        StrokeShape="RoundRectangle 2"
                        Stroke="#40000000"
                        StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,2"
                                Opacity="0.25"
                                Radius="2"/>
                    </Border.Shadow>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            DefaultAnimationDuration="150"
                            PressedOpacity="0.8"
                            PressedScale="0.97"
                            TouchGestureCompleted="OnFavoriteTapped"
                            LongPressCompleted="OnOptionsLongPressed"/>
                    </Border.Behaviors>
                    <outline:OutlinedLabel Text="FAVORITE"
                                           FontFamily="PoppinsBlack"
                                           FontSize="18"
                                           TextColor="#EDF8EA"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           StrokeColor="#40000000"
                                           StrokeWidth="2"
                                           HasShadow="True"
                                           ShadowColor="#40000000"
                                           ShadowBlur="2"
                                           ShadowOffsetY="2">
                                    <outline:OutlinedLabel.Triggers>
                                        <DataTrigger TargetType="outline:OutlinedLabel"
                                                     Binding="{Binding Model.IsFavorite}"
                                                     Value="True">
                                            <Setter Property="Text"
                                                    Value="UNFAVORITE"/>
                                        </DataTrigger>
                                    </outline:OutlinedLabel.Triggers>
                    </outline:OutlinedLabel>
                </Border>

                <!-- Squad #1 Button -->
                <Border Grid.Row="2"
                        Background="{StaticResource SpiritsForegroundButton}"
                        StrokeShape="RoundRectangle 2"
                        Stroke="#40000000"
                        StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,2"
                                Opacity="0.25"
                                Radius="2"/>
                    </Border.Shadow>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            DefaultAnimationDuration="150"
                            PressedOpacity="0.8"
                            PressedScale="0.97"
                            TouchGestureCompleted="OnSquad1Tapped"
                            LongPressCompleted="OnOptionsLongPressed"/>
                    </Border.Behaviors>
                    <outline:OutlinedLabel Text="SQUAD #1"
                                           FontFamily="PoppinsBlack"
                                           FontSize="18"
                                           TextColor="#FFE368"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           StrokeColor="#BA7412"
                                           StrokeWidth="2"
                                           HasShadow="True"
                                           ShadowBlur="2"
                                           ShadowOffsetY="2"/>
                </Border>

                <!-- Squad #2 Button -->
                <Border Grid.Row="3"
                        Background="{StaticResource SpiritsForegroundButton}"
                        StrokeShape="RoundRectangle 2"
                        Stroke="#40000000"
                        StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,2"
                                Opacity="0.25"
                                Radius="2"/>
                    </Border.Shadow>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            DefaultAnimationDuration="150"
                            PressedOpacity="0.8"
                            PressedScale="0.97"
                            TouchGestureCompleted="OnSquad2Tapped"
                            LongPressCompleted="OnOptionsLongPressed"/>
                    </Border.Behaviors>
                    <outline:OutlinedLabel Text="SQUAD #2"
                                           FontFamily="PoppinsBlack"
                                           FontSize="18"
                                           TextColor="#FFE368"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           StrokeColor="#BA7412"
                                           StrokeWidth="2"
                                           HasShadow="True"
                                           ShadowBlur="2"
                                           ShadowOffsetY="2"/>
                </Border>

                <!-- Squad #3 Button -->
                <Border Grid.Row="4"
                        Background="{StaticResource SpiritsForegroundButton}"
                        StrokeShape="RoundRectangle 2"
                        Stroke="#40000000"
                        StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,2"
                                Opacity="0.25"
                                Radius="2"/>
                    </Border.Shadow>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            DefaultAnimationDuration="150"
                            PressedOpacity="0.8"
                            PressedScale="0.97"
                            TouchGestureCompleted="OnSquad3Tapped"
                            LongPressCompleted="OnOptionsLongPressed"/>
                    </Border.Behaviors>
                    <outline:OutlinedLabel Text="SQUAD #3"
                                           FontFamily="PoppinsBlack"
                                           FontSize="18"
                                           TextColor="#FFE368"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           StrokeColor="#BA7412"
                                           StrokeWidth="2"
                                           HasShadow="True"
                                           ShadowBlur="2"
                                           ShadowOffsetY="2"/>
                </Border>

            </Grid>
        </Border>

    </Grid>
</ContentView>
