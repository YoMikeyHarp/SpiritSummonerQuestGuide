<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="SpiritSummoner.Presentation.Views.Popups.Shared.CustomAlertPopup"
             xmlns:vm="clr-namespace:SpiritSummoner.Presentation.ViewModels.Popups"
             x:DataType="vm:CustomAlertPopupViewModel"
             CanBeDismissedByTappingOutsideOfPopup="False">

    <Border BackgroundColor="#F5DD91"
            StrokeShape="RoundRectangle 4"
            Padding="10"
            Stroke="{Binding StrokeColor}"
            StrokeThickness="7"
            WidthRequest="350"
            MaximumWidthRequest="400">
        <Border.Shadow>
            <Shadow Brush="LightGoldenrodYellow"
                   Offset="1,0"
                   Radius="25"/>
        </Border.Shadow>

        <Grid Padding="15" RowDefinitions="Auto, Auto, Auto" RowSpacing="20">

            <!-- Title -->
            <Label Text="{Binding Title}"
                   Grid.Row="0"
                   HorizontalOptions="Center"
                   FontFamily="Poppins"
                   FontAttributes="Bold"
                   TextColor="White"
                   FontSize="28">
                <Label.Shadow>
                    <Shadow Brush="Black"
                            Offset="0,0"
                            Radius="3"/>
                </Label.Shadow>
            </Label>

            <!-- Message -->
            <Label Text="{Binding Message}"
                   Grid.Row="1"
                   FontFamily="Poppins"
                   TextColor="Black"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   FontSize="Medium"
                   Margin="0,10,0,0"/>

            <!-- OK Button -->
            <Border Grid.Row="2"
                    StrokeShape="RoundRectangle 8"
                    Stroke="#D4A627"
                    StrokeThickness="3"
                    Padding="0"
                    HorizontalOptions="Center"
                    WidthRequest="150"
                    Margin="0,10,0,0">
                <Border.Shadow>
                    <Shadow Brush="DarkGoldenrod"
                            Offset="1,-1"
                            Radius="5"
                            Opacity="0.7"/>
                </Border.Shadow>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFD700" Offset="0.0"/>
                        <GradientStop Color="#FFA500" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Label Text="OK"
                       FontFamily="Poppins"
                       FontAttributes="Bold"
                       FontSize="Large"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Padding="20,10">
                    <Label.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,1"
                                Radius="2"/>
                    </Label.Shadow>
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OkCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Border>

        </Grid>
    </Border>

</toolkit:Popup>
