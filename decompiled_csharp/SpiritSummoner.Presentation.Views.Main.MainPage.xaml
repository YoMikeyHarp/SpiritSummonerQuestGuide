<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="SpiritSummoner.Presentation.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:cnv="clr-namespace:SpiritSummoner.Presentation.Converters"
    xmlns:controlvm="clr-namespace:SpiritSummoner.Presentation.Models"
    xmlns:local="clr-namespace:SpiritSummoner.Presentation.Views.Animations"
    xmlns:maui="clr-namespace:epj.ProgressBar.Maui;assembly=epj.ProgressBar.Maui"
    xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
    xmlns:models="clr-namespace:SpiritSummoner.Presentation.Models"
    xmlns:outline="clr-namespace:SpiritSummoner.Presentation.ViewModels.Shared"
    xmlns:shared="clr-namespace:SpiritSummoner.Presentation.Views.Shared"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:SpiritSummoner.Presentation.ViewModels.StartUp"
    x:DataType="vm:MainViewModel">

    <ContentView.Resources>
        <cnv:BonusToStarsConverter x:Key="BonusToStarsConverter" />
    </ContentView.Resources>


    <!--  Main Content  -->
    <Grid
        Padding="10"
        ColumnDefinitions="*,0.9*"
        ColumnSpacing="20"
        RowDefinitions="Auto, Auto,*,Auto,Auto">

        <Grid
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Padding="5,5"
            ColumnDefinitions="*,*,*"
            ColumnSpacing="20"
            HeightRequest="60">
            
            <!--  Battle Pass Button  -->
            <Border
                Grid.Column="0"
                Padding="0"
                StrokeShape="RoundRectangle 6">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0.0" Color="#E99F6A" />
                        <GradientStop Offset="0.1" Color="#D6680F" />
                        <GradientStop Offset="0.8" Color="#D6680F" />
                        <GradientStop Offset="1.0" Color="#B2590A" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>

                    <Image
                        HeightRequest="35"
                        HorizontalOptions="Start"
                        Source="icon_ticket_new.png"
                        ZIndex="2" />
                    <Grid Padding="10,5">
                        <Border BackgroundColor="#FFF2B0" StrokeShape="RoundRectangle 4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0.0" Color="#FED571" />
                                    <GradientStop Offset="0.2548" Color="#FEF093" />
                                    <GradientStop Offset="0.5" Color="#FEF89D" />
                                    <GradientStop Offset="0.75" Color="#FEF093" />
                                    <GradientStop Offset="1.0" Color="#FED571" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <VerticalStackLayout VerticalOptions="Center">
                                <outline:OutlinedLabel
                                    Margin="15,0,0,0"
                                    FontFamily="PoppinsBold"
                                    FontSize="13.5"
                                    HasShadow="True"
                                    HorizontalOptions="Center"
                                    ShadowBlur="1"
                                    ShadowColor="#40000000"
                                    ShadowOffsetX="0"
                                    ShadowOffsetY="1"
                                    StrokeColor="#EDF9F1B5"
                                    StrokeWidth="3"
                                    Text="BATTLE"
                                    TextColor="#954F14"
                                    VerticalOptions="Start" />

                                <outline:OutlinedLabel
                                    Margin="15,0,0,0"
                                    FontFamily="PoppinsBold"
                                    FontSize="13.5"
                                    HasShadow="True"
                                    HorizontalOptions="Center"
                                    ShadowBlur="1"
                                    ShadowColor="#40000000"
                                    ShadowOffsetX="0"
                                    ShadowOffsetY="1"
                                    StrokeColor="#EDF9F1B5"
                                    StrokeWidth="3"
                                    Text="PASS"
                                    TextColor="#954F14"
                                    VerticalOptions="Start" />
                            </VerticalStackLayout>

                        </Border>
                    </Grid>

                </Grid>

            </Border>

            <!--  Game News Button  -->
            <Border
                Grid.Column="1"
                Padding="0"
                StrokeShape="RoundRectangle 6">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0.0" Color="#E99F6A" />
                        <GradientStop Offset="0.1" Color="#D6680F" />
                        <GradientStop Offset="0.8" Color="#D6680F" />
                        <GradientStop Offset="1.0" Color="#B2590A" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenGameNewsCommand}" />
                </Border.GestureRecognizers>
                <Grid>
                    <Image
                        HeightRequest="35"
                        HorizontalOptions="Start"
                        Source="newicon.png"
                        ZIndex="2" />

                    <Grid Padding="10,5">
                        <Border BackgroundColor="#FFF2B0" StrokeShape="RoundRectangle 4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0.0" Color="#FED571" />
                                    <GradientStop Offset="0.2548" Color="#FEF093" />
                                    <GradientStop Offset="0.5" Color="#FEF89D" />
                                    <GradientStop Offset="0.75" Color="#FEF093" />
                                    <GradientStop Offset="1.0" Color="#FED571" />
                                </LinearGradientBrush>
                            </Border.Background>

                            <VerticalStackLayout VerticalOptions="Center">
                                <outline:OutlinedLabel
                        Margin="15,0,0,0"
                        FontFamily="PoppinsBold"
                        FontSize="14"
                        HasShadow="True"
                        HorizontalOptions="Center"
                        ShadowBlur="1"
                        ShadowColor="#40000000"
                        ShadowOffsetX="0"
                        ShadowOffsetY="1"
                        StrokeColor="#EDF9F1B5"
                        StrokeWidth="3"
                        Text="GAME"
                        TextColor="#954F14"
                        VerticalOptions="Start" />

                                <outline:OutlinedLabel
                        Margin="15,0,0,0"
                        FontFamily="PoppinsBold"
                        FontSize="14"
                        HasShadow="True"
                        HorizontalOptions="Center"
                        ShadowBlur="1"
                        ShadowColor="#40000000"
                        ShadowOffsetX="0"
                        ShadowOffsetY="1"
                        StrokeColor="#EDF9F1B5"
                        StrokeWidth="3"
                        Text="NEWS"
                        TextColor="#954F14"
                        VerticalOptions="Start" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!--  Daily Gifts Button  -->
            <Grid Grid.Column="2">
                <Border
                    Padding="0"
                    StrokeShape="RoundRectangle 6">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0.0" Color="#E99F6A" />
                            <GradientStop Offset="0.1" Color="#D6680F" />
                            <GradientStop Offset="0.8" Color="#D6680F" />
                            <GradientStop Offset="1.0" Color="#B2590A" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenDailyGiftsCommand}" />
                    </Border.GestureRecognizers>
                    <Grid>

                        <Image
                            HeightRequest="35"
                            HorizontalOptions="Start"
                            Source="icon_daily_gifts.png"
                            ZIndex="2" />
                        <Grid Padding="10,5">
                            <Border BackgroundColor="#FFF2B0" StrokeShape="RoundRectangle 4">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0.0" Color="#FED571" />
                                        <GradientStop Offset="0.2548" Color="#FEF093" />
                                        <GradientStop Offset="0.5" Color="#FEF89D" />
                                        <GradientStop Offset="0.75" Color="#FEF093" />
                                        <GradientStop Offset="1.0" Color="#FED571" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <VerticalStackLayout VerticalOptions="Center">
                                    <outline:OutlinedLabel
                                        Margin="15,0,0,0"
                                        FontFamily="PoppinsBold"
                                        FontSize="14"
                                        HasShadow="True"
                                        HorizontalOptions="Center"
                                        ShadowBlur="1"
                                        ShadowColor="#40000000"
                                        ShadowOffsetX="0"
                                        ShadowOffsetY="1"
                                        StrokeColor="#EDF9F1B5"
                                        StrokeWidth="3"
                                        Text="DAILY"
                                        TextColor="#954F14"
                                        VerticalOptions="Start" />

                                    <outline:OutlinedLabel
                                        Margin="15,0,0,0"
                                        FontFamily="PoppinsBold"
                                        FontSize="14"
                                        HasShadow="True"
                                        HorizontalOptions="Center"
                                        ShadowBlur="1"
                                        ShadowColor="#40000000"
                                        ShadowOffsetX="0"
                                        ShadowOffsetY="1"
                                        StrokeColor="#EDF9F1B5"
                                        StrokeWidth="3"
                                        Text="GIFTS"
                                        TextColor="#954F14"
                                        VerticalOptions="Start" />
                                </VerticalStackLayout>

                            </Border>
                        </Grid>

                    </Grid>

                </Border>

                <!--  Badge count  -->
                <Border
                    WidthRequest="20"
                    HeightRequest="20"
                    BackgroundColor="#E53F37"
                    StrokeShape="Ellipse"
                    Stroke="White"
                    StrokeThickness="1.5"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    TranslationX="5"
                    TranslationY="-5"
                    IsVisible="{Binding DailyGiftCount, Converter={StaticResource IsPositiveConverter}}"
                    ZIndex="3">
                    <Label
                        Text="{Binding DailyGiftCount}"
                        FontSize="9"
                        FontFamily="PoppinsBold"
                        TextColor="White"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Border>
            </Grid>

        </Grid>


        <!--  Spirit Info  -->
        <Grid
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Padding="-10,15,-10,0"
            ColumnDefinitions="90, * , 90"
            RowDefinitions="10, *">

            <Border
                Grid.Row="1"
                Grid.Column="0"
                Padding="5,0"
                HeightRequest="15"
                HorizontalOptions="Start"
                Stroke="Black"
                StrokeShape="RoundRectangle 0,4,0,4"
                StrokeThickness="0.5"
                VerticalOptions="Center"
                WidthRequest="80">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0.0" Color="#A8CB3F" />
                        <GradientStop Offset="0.6202" Color="#7DB813" />
                        <GradientStop Offset="1.0" Color="#7DB813" />
                    </LinearGradientBrush>
                </Border.Background>
                <Label
                    FontFamily="PoppinsBold"
                    FontSize="10"
                    Text="LVL"
                    TextColor="#EDF8EA">
                    <Label.Shadow>
                        <Shadow Brush="#000000" Offset="1,1" />
                    </Label.Shadow>
                </Label>
            </Border>

            <outline:OutlinedLabel
                Grid.Row="1"
                Grid.Column="0"
                FontFamily="Bungee"
                FontSize="32"
                HasShadow="True"
                HorizontalOptions="Center"
                ShadowBlur="2"
                ShadowColor="#40000000"
                ShadowOffsetY="2"
                StrokeColor="#43781C"
                StrokeWidth="3.5"
                Text="{Binding PartnerSpirit.Model.Level}"
                TextColor="#EDF8EA" />

            <!--  Separator  -->
            <BoxView
                Grid.Row="1"
                Grid.Column="0"
                BackgroundColor="White"
                HorizontalOptions="End"
                Opacity="0.5"
                ScaleY="0.7"
                WidthRequest="1" />

            <outline:OutlinedLabel
                Grid.Row="0"
                Grid.Column="1"
                FontFamily="PoppinsSemiBold"
                FontSize="12"
                HorizontalOptions="Center"
                Text="{Binding PartnerSpirit.Model.Class}"
                TextColor="Gray"
                VerticalOptions="Start"
                ZIndex="2" />

            <outline:OutlinedLabel
                Grid.Row="1"
                Grid.Column="1"
                FontFamily="PoppinsBlack"
                FontSize="{Binding PartnerSpirit.Model.Nickname, Converter={StaticResource NicknameToFontSizeConverter}, ConverterParameter=37}"
                HasShadow="True"
                HorizontalOptions="Center"
                ShadowBlur="2"
                ShadowColor="#40000000"
                ShadowOffsetY="2"
                StrokeColor="#43781C"
                StrokeWidth="3.5"
                MaximumWidthRequest="{OnIdiom Phone=300, Tablet=320, Default=220}"
                Text="{Binding PartnerSpirit.Model.Nickname}"
                TextColor="#EDF8EA"
                ZIndex="1" />

            <Border
                Grid.Row="1"
                Grid.Column="2"
                HeightRequest="15"
                HorizontalOptions="End"
                Stroke="Black"
                StrokeShape="RoundRectangle 4,0,4,0"
                StrokeThickness="0.5"
                VerticalOptions="Center"
                WidthRequest="80">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0.0" Color="#A8CB3F" />
                        <GradientStop Offset="0.6202" Color="#7DB813" />
                        <GradientStop Offset="1.0" Color="#7DB813" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <HorizontalStackLayout
                Grid.Row="1"
                Grid.Column="2"
                HeightRequest="35"
                HorizontalOptions="Center">
                <Image
                    Aspect="AspectFit"
                    HeightRequest="35"
                    Source="{Binding PartnerSpirit.Model.Type1, Converter={StaticResource NameToImageConverter}}" />
                <Image
                    Aspect="AspectFit"
                    HeightRequest="35"
                    Source="{Binding PartnerSpirit.Model.Type2, Converter={StaticResource NameToImageConverter}}" />

            </HorizontalStackLayout>



            <!--  Separator  -->
            <BoxView
                Grid.Row="1"
                Grid.Column="2"
                BackgroundColor="White"
                HorizontalOptions="Start"
                Opacity="0.5"
                ScaleY="0.7"
                WidthRequest="1" />
        </Grid>


        <!--  Spirit Image  -->
        <Grid Grid.Row="2" Grid.ColumnSpan="3">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding NavigateToSpiritDetailsCommand}" CommandParameter="{Binding PartnerSpirit.Model.PlayerSpiritId}" />
            </Grid.GestureRecognizers>

            <Grid ZIndex="1">
                <local:BouncingImage
                    Aspect="AspectFit"
                    HorizontalOptions="Center"
                    Source="{Binding PartnerSpirit.Model.Image}"
                    VerticalOptions="Start" />
            </Grid>

            <Grid Padding="5,0,5,-25">
                <Image
                    Aspect="AspectFit"
                    HorizontalOptions="Center"
                    Source="{Binding PartnerSpirit.Model.Type1, Converter={StaticResource PlatformImageConverter}}"
                    TranslationY="20"
                    VerticalOptions="End">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToSpiritDetailsCommand}" CommandParameter="{Binding PartnerSpirit.Model.PlayerSpiritId}" />
                    </Image.GestureRecognizers>
                </Image>
            </Grid>

        </Grid>

        <!--  Attributes  -->
        <Grid
            Grid.Row="3"
            Grid.Column="0"
            Padding="0">
            <Border
                Padding="7"
                BackgroundColor="#83CF63"
                Stroke="#EDF8EA"
                StrokeThickness="2.5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow
                        Brush="#40000000"
                        Opacity="0.9"
                        Radius="1"
                        Offset="0,0.5" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding PartnerSpirit.EditAttributesCommand}" />
                </Border.GestureRecognizers>

                <CollectionView
                    ItemsSource="{Binding PartnerSpirit.Model.Attributes}"
                    VerticalOptions="Center"
                    VerticalScrollBarVisibility="Never">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout ItemSpacing="9" Orientation="Vertical" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="controlvm:AttributeProgressModel">
                            <Grid ColumnDefinitions="20,30,*" ColumnSpacing="15">

                                <!--  Background Rectangle with Radial Gradient  -->
                                <Image Grid.Column="0" Source="rectangle80.svg" />

                                <Image
                                    Grid.Column="0"
                                    Aspect="AspectFit"
                                    Source="{Binding Icon}" />



                                <!--  Attribute Name  -->
                                <outline:OutlinedLabel
                                    Grid.Column="1"
                                    FontFamily="PoppinsSemiBold"
                                    FontSize="14"
                                    HasShadow="True"
                                    ShadowBlur="1"
                                    ShadowColor="#40000000"
                                    ShadowOffsetX="0"
                                    ShadowOffsetY="1"
                                    StrokeColor="#FF454545"
                                    StrokeWidth="1"
                                    Text="{Binding Name}"
                                    TextColor="#EDF8EA"
                                    VerticalOptions="Center" />

                                <maui:ProgressBar
                                    Grid.Column="2"
                                    BaseColor="Transparent"
                                    HeightRequest="8"
                                    Progress="{Binding BaseProgress}"
                                    ProgressColor="Green"
                                    RoundCaps="True"
                                    ZIndex="2" />

                                <maui:ProgressBar
                                    Grid.Column="2"
                                    BaseColor="Transparent"
                                    HeightRequest="8"
                                    Progress="{Binding BonusProgress}"
                                    ProgressColor="Gold"
                                    RoundCaps="True"
                                    ZIndex="1" />

                                <maui:ProgressBar
                                            Grid.Column="2"
                                            BaseColor="Transparent"
                                            HeightRequest="8"
                                            Progress="{Binding ItemBuffProgress}"
                                            ProgressColor="{Binding IsItemBuffNegative, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#E53F37,#4CAF50'}"
                                            RoundCaps="True"
                                            ZIndex="0" />

                                <HorizontalStackLayout
                                    Grid.Column="2"
                                    BindableLayout.ItemsSource="{Binding BonusMultiplier, Converter={StaticResource BonusToStarsConverter}}"
                                    HorizontalOptions="Start"
                                    Spacing="2"
                                    VerticalOptions="Center"
                                    ZIndex="2">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Image
                                                Aspect="AspectFit"
                                                HeightRequest="12"
                                                Scale="1.5"
                                                Source="{Binding .}"
                                                TranslationY="-3"
                                                WidthRequest="12" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </HorizontalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>
        </Grid>



        <!--  Talent, Gear & Moves  -->
        <Grid
            Grid.Row="3"
            Grid.Column="1"
            Padding="0"
            RowDefinitions="*,*,*"
            RowSpacing="15">
            <!--  Talent Button  -->
            <Border
                x:Name="TalentBorder"
                Grid.Row="1"
                BackgroundColor="#83CF63"
                Stroke="#EDF8EA"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="2.5">
                <Border.Behaviors>
                    <toolkit:TouchBehavior
                        DefaultAnimationDuration="250"
                        DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                        PressedOpacity="0.6"
                        PressedScale="0.7" />
                </Border.Behaviors>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding PartnerSpirit.EditTalentCommand}" />
                </Border.GestureRecognizers>
                <Grid
                    Padding="10"
                    ColumnDefinitions="40,*,10"
                    ColumnSpacing="5">

                    <VerticalStackLayout
                        Grid.ColumnSpan="3"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        IsVisible="{Binding PartnerSpirit.HasTalent,Converter={StaticResource InverseBooleanConverter}}">
                        <Label
                            Grid.ColumnSpan="3"
                            FontFamily="PoppinsSemiBold"
                            FontSize="12"
                            HorizontalOptions="Center"
                            Text="- NO TALENT - "
                            TextColor="Gray"
                            VerticalOptions="Start" />
                        <Label
                            Grid.ColumnSpan="3"
                            FontFamily="Poppins"
                            FontSize="10"
                            HorizontalOptions="Center"
                            Opacity="0.9"
                            Text="(TAP TO ADD TALENT)"
                            TextColor="Gray" />
                    </VerticalStackLayout>


                    <!--  Icon  -->
                    <Image
                        Grid.Column="0"
                        IsVisible="{Binding PartnerSpirit.HasTalent}"
                        TranslationX="-5"
                        Aspect="AspectFit"
                        Source="{Binding PartnerSpirit.Talent.Icon}" />
                    <StackLayout
                        Grid.Column="1"
                        IsVisible="{Binding PartnerSpirit.HasTalent}"
                        VerticalOptions="Center">
                        <!--  Text  -->
                        <Label
                            Grid.Column="1"
                            HorizontalTextAlignment="Center"
                            FontFamily="PoppinsSemiBold"
                            FontSize="10"
                            Text="Talent"
                            TextColor="#40000000">
                        </Label>

                        <!--  Text  -->
                        <outline:OutlinedLabel Grid.Column="1"
                            FontFamily="PoppinsSemiBold"
                            FontSize="13"
                            Text="{Binding PartnerSpirit.Talent.Name}"
                            TextColor="#C96D1E"
                            StrokeColor="#EDF8EA"
                            StrokeWidth="1"
                            HasShadow="True"
                            ShadowColor="#40000000"
                            ShadowBlur="1"
                            ShadowOffsetY="1"
                            ShadowOffsetX="0"/>
                    </StackLayout>


                    <Image Grid.Column="2" Source="{mi:FontAwesomeSolid Icon=ArrowRight, IconColor=Gray}" />

                </Grid>
            </Border>

            <!--  Gear Button  -->
            <Border
                x:Name="GearBorder"
                Grid.Row="0"
                BackgroundColor="#83CF63"
                Stroke="#EDF8EA"
                StrokeThickness="2.5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Border.Behaviors>
                    <toolkit:TouchBehavior
                        DefaultAnimationDuration="250"
                        DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                        PressedOpacity="0.6"
                        PressedScale="0.7" />
                </Border.Behaviors>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding PartnerSpirit.EditGearCommand}" />
                </Border.GestureRecognizers>
                <Grid
                    Padding="10"
                    ColumnDefinitions="30,*,10"
                    ColumnSpacing="5">

                    <VerticalStackLayout
                        Grid.ColumnSpan="3"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        IsVisible="{Binding PartnerSpirit.HasGear,Converter={StaticResource InverseBooleanConverter}}">
                        <Label
                            Grid.ColumnSpan="3"
                            FontFamily="PoppinsSemiBold"
                            FontSize="12"
                            HorizontalOptions="Center"
                            Text="- NO GEAR - "
                            TextColor="Gray"
                            VerticalOptions="Start" />
                        <Label
                            Grid.ColumnSpan="3"
                            FontFamily="Poppins"
                            FontSize="10"
                            HorizontalOptions="Center"
                            Opacity=".8"
                            Text="(TAP TO ADD GEAR)"
                            TextColor="Gray" />
                    </VerticalStackLayout>
                    <!--  Icon  -->
                    <Image
                        Grid.Column="0"
                        IsVisible="{Binding PartnerSpirit.HasGear}"
                        TranslationX="-5"
                        Aspect="AspectFit"
                        Source="{Binding PartnerSpirit.Gear.Icon}" />
                    <StackLayout
                        Grid.Column="1"
                        IsVisible="{Binding PartnerSpirit.HasGear}"
                        VerticalOptions="Center">
                        <!--  Text  -->
                        <Label
                            Grid.Column="1"
                            HorizontalTextAlignment="Center"
                            FontFamily="PoppinsSemiBold"
                            FontSize="10"
                            Text="GEAR"
                            TextColor="#40000000">
                        </Label>

                        <!--  Text  -->
                        <outline:OutlinedLabel Grid.Column="1"
                            FontFamily="PoppinsSemiBold"
                            FontSize="13"
                            Text="{Binding PartnerSpirit.Gear.Name}"
                            TextColor="#C96D1E"
                            StrokeColor="#EDF8EA"
                            StrokeWidth="1"
                            HasShadow="True"
                            ShadowColor="#40000000"
                            ShadowBlur="1"
                            ShadowOffsetY="1"
                            ShadowOffsetX="0"/>
                    </StackLayout>


                    <Image Grid.Column="2" Source="{mi:FontAwesomeSolid Icon=ArrowRight, IconColor=Gray}" />

                </Grid>
            </Border>

            <!--  Moves  -->
            <Border
                Grid.Row="3"
                BackgroundColor="#7CCB59"
                Stroke="#EDF8EA"
                Padding="3,5"
                StrokeThickness="2.5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Border.Behaviors>
                    <toolkit:TouchBehavior
                        DefaultAnimationDuration="250"
                        DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                        PressedOpacity="0.6"
                        PressedScale="0.7" />
                </Border.Behaviors>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding EditMovesCommand}" />
                </Border.GestureRecognizers>
                <Grid Padding="10,5" ColumnDefinitions="*,10">

                    <CollectionView Grid.Column="0" ItemsSource="{Binding PartnerSpirit.Model.SpiritMoves}" HorizontalScrollBarVisibility="Never">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="5" Orientation="Horizontal" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:MoveEditableState">
                                <Image
                                    Aspect="AspectFit"
                                    HeightRequest="28"
                                    Opacity="{Binding IsActive, Converter={StaticResource BoolToOpacityConverter}}"
                                    Source="{Binding Type, Converter={StaticResource NameToImageConverter}}"
                                    WidthRequest="28" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Image
                        Grid.Column="1"
                        HeightRequest="12"
                        Aspect="AspectFit"
                        Source="{mi:FontAwesomeSolid Icon=ArrowRight,
                                                     IconColor=Gray}" />
                </Grid>

            </Border>

        </Grid>

        <Border Grid.Row="4"
                Grid.ColumnSpan="2"
                Padding="10"
                StrokeShape="RoundRectangle 8"
                Background="{StaticResource GradientRewards}"
                HorizontalOptions="Fill"
                HeightRequest="30"
                IsVisible="{Binding HasGuildInvite}">
                <Border.Behaviors>
                    <toolkit:TouchBehavior
                        DefaultAnimationDuration="250"
                        DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                        PressedOpacity="0.6"
                        PressedScale="0.7" />
                </Border.Behaviors>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenInvitationsCommand}"
                                          CommandParameter="//guild"/>
                </Border.GestureRecognizers>

            <outline:OutlinedLabel Text="You have been invited to join a guild!"
                   TextColor="#EDF8EA"
                   FontFamily="PoppinsSemiBold"
                   FontSize="14"
                   StrokeColor="#40000000"
                   HasShadow="True"
                   ShadowColor="#4D000000"
                   ShadowBlur="1"
                   ShadowOffsetY="1"
                   ShadowOffsetX="0"/>


        </Border>

    </Grid>


</ContentView>

