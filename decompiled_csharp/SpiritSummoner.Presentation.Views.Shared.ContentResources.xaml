<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="SpiritSummoner.Presentation.Views.Shared.ContentResources"
                    xmlns:outline="clr-namespace:SpiritSummoner.Presentation.ViewModels.Shared">
                    
        <Style x:Key="BungeeHeader"
               TargetType="Label">
                <Setter Property="FontFamily"
                        Value="PoppinsSemiBold"/>
                <Setter Property="FontSize"
                        Value="28"/>
                <Setter Property="TextColor"
                        Value="White"/>
                <Setter Property="FontAttributes"
                        Value="Bold"/>
        </Style>

        <Style x:Key="GradientButton"
               TargetType="Button">
                <Setter Property="Background">
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,1">
                                <GradientStop Color="#FCECA0"
                                              Offset="0"/>
                                <GradientStop Color="#FFDD78"
                                              Offset="0.5"/>
                                <GradientStop Color="#F99602"
                                              Offset="1"/>
                        </LinearGradientBrush>
                </Setter>
                <Setter Property="CornerRadius"
                        Value="100"/>
        </Style>

        <LinearGradientBrush x:Key="VictoryPopupGradient"
                             StartPoint="0.5,0"
                             EndPoint="0.5,1">
                <GradientStop Color="#78CB55"
                              Offset="0"/>
                <GradientStop Color="#9EDA84"
                              Offset="0.5"/>
                <GradientStop Color="#67C441"
                              Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DefeatPopupGradient"
                             StartPoint="0.5,0"
                             EndPoint="0.5,1">
                <GradientStop Color="#CB5560"
                              Offset="0"/>
                <GradientStop Color="#DA848D"
                              Offset="0.5"/>
                <GradientStop Color="#CB5560"
                              Offset="1"/>
        </LinearGradientBrush>

