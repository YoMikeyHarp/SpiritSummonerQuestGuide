<?xml version="1.0" encoding="UTF-8" ?>
<Shell
        x:Class="SpiritSummoner.AppShell"
        xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
        Shell.FlyoutBehavior="Disabled"
        xmlns:views="clr-namespace:SpiritSummoner.Presentation.Views"
        Shell.NavBarIsVisible="False">

        <ShellContent Route="welcome"
                      ContentTemplate="{DataTemplate views:WelcomePage}"/>

        <ShellContent Route="login"
                      ContentTemplate="{DataTemplate views:LoginPage}"/>

        <ShellContent Route="loading"
                      ContentTemplate="{DataTemplate views:LoadingPage}"/>

        <ShellContent Route="master"
                      ContentTemplate="{DataTemplate views:MasterPage}"/>

</Shell>
