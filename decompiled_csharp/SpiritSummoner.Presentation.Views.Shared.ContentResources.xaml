        <LinearGradientBrush x:Key="GradientBackgroundSpiritSimple"
                             StartPoint="1,0"
                             EndPoint="0,1">
                <GradientStop Color="#8DE0F0"
                              Offset="0"/>
                <GradientStop Color="#8DE0F0"
                              Offset="0.2"/>
                <GradientStop Color="#85DDEE"
                              Offset="0.9"/>
        </LinearGradientBrush>

        <!-- Radial Gradient for Button Background -->
        <RadialGradientBrush x:Key="ButtonBackgroundGradient"
                             Center="0.5,0.2"
                             Radius="0.5">
                <GradientStop Color="#FCECA0"
                              Offset="0"/>
                <GradientStop Color="#FFDD78"
                              Offset="0.5"/>
                <GradientStop Color="#F99602"
                              Offset="1"/>
