<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SpiritSummoner.Presentation.ViewModels.Onboarding"
             xmlns:outline="clr-namespace:SpiritSummoner.Presentation.ViewModels.Shared"
             x:Class="SpiritSummoner.Presentation.Views.Onboarding.OnboardingDialoguePage"
             x:DataType="vm:OnboardingViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <ContentPage.Background>
        <!-- Blue gradient: #8EE0F0 → #A1E5F3 → #AEE9F5 → #8EE0F0 → #85DDEE -->
        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#8EE0F0" Offset="0"/>
            <GradientStop Color="#A1E5F3" Offset="0.25"/>
            <GradientStop Color="#AEE9F5" Offset="0.495"/>
            <GradientStop Color="#8EE0F0" Offset="0.75"/>
            <GradientStop Color="#85DDEE" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="*, Auto, Auto" RowSpacing="90">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding TapToContinueCommand}"/>
        </Grid.GestureRecognizers>

        <!-- Pattern overlay at 5% opacity -->
        <Image Source="circles_overlap.png"
               Aspect="AspectFit"
               VerticalOptions="Fill"
               Grid.RowSpan="3"
               Opacity="1"/>

        <!-- Character Images Area -->
        
        <!-- Primary character image -->
        <Image Source="{Binding CharacterImage1}"
               Aspect="AspectFit"
               Grid.Row="0"
               Grid.RowSpan="1"
               TranslationY="-60"
               TranslationX="-90">
            <Image.Shadow>
                <Shadow Brush="#40000000"
                        Offset="0,5 "
                        Radius="0"/>
            </Image.Shadow>
        </Image>

        <!-- Optional second character (offset) -->
        <Image Source="{Binding CharacterImage2}"
               Aspect="AspectFit"
               Grid.Row="0"
               Grid.RowSpan="2"
               TranslationX="-10"
               TranslationY="-120"
               IsVisible="{Binding HasSecondCharacter}">
            <Image.Shadow>
                <Shadow Brush="#EDF8EA"
                        Offset="0,1"
                        Radius="5"/>
            </Image.Shadow>
        </Image>

        <Grid Grid.Row="0"
              Grid.RowSpan="2"
              VerticalOptions="End"
              Padding="10,0">

            <!-- Dialogue Box -->
            <Border Grid.Row="1"
                    HorizontalOptions="Center"
                    Padding="10"
                    HeightRequest="240"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="#C9EFB6"
                    Stroke="#7FBE6A"
                    StrokeThickness="3">

                <Grid RowDefinitions="Auto, *" RowSpacing="5">
                    <!-- Speaker Name -->
                    <outline:OutlinedLabel Text="{Binding SpeakerName}"
                                        Grid.Row="0"
                                        HorizontalOptions="Start"
                                        FontFamily="PoppinsBold"
                                        FontSize="22"
                                        TextColor="#16A742"
                                        HasShadow="True"
                                        ShadowColor="#40000000"
                                        ShadowBlur="1"
                                        ShadowOffsetY="1"/>

                    <!-- Inner white box for dialogue -->
                    <Border Grid.Row="1"
                            Padding="12"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="#EDF8EA"
                            Stroke="#40000000"
                            StrokeThickness="1">

                        <!-- Dialogue Text -->
                        <Label Text="{Binding DialogueText}"
                            FontFamily="PoppinsMedium"
                            FontSize="16"
                            TextColor="Black"
                            LineBreakMode="WordWrap"
                            LineHeight="1.4"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Tap to Continue -->
        <outline:OutlinedLabel Grid.Row="2"
                               Text="Tap to Continue"
                               FontFamily="PoppinsBold"
                               FontSize="24"
                               TextColor="#2E4354"
                               StrokeColor="#EDF8EA"
                               StrokeWidth="1"
                               HorizontalOptions="Center"
                               Margin="0,0,0,50"
                               HasShadow="True"
                               ShadowOffsetX="0"
                               ShadowOffsetY="2"
                               ShadowBlur="2"
                               ShadowColor="#40000000"/>
    </Grid>
</ContentPage>
