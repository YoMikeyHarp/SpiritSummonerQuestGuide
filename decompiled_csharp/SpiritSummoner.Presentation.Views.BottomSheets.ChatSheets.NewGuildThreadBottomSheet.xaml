<?xml version="1.0" encoding="utf-8" ?>
<the49:BottomSheet xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                   xmlns:the49="https://schemas.the49.com/dotnet/2023/maui"
                   xmlns:vm="clr-namespace:SpiritSummoner.Presentation.ViewModels.BottomSheet"
                   xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
                   xmlns:cnv="clr-namespace:SpiritSummoner.Presentation.Converters"
                   xmlns:outline="clr-namespace:SpiritSummoner.Presentation.ViewModels.Shared"
                   HasBackdrop="True"
                   IsCancelable="true"
                   Dismissed="BottomSheet_Dismissed"
                   BackgroundColor="Transparent"
                   x:Class="SpiritSummoner.Presentation.Views.BottomSheets.ChatSheets.NewGuildThreadBottomSheet"
                   x:DataType="vm:NewGuildThreadSheetViewModel">

    <Grid VerticalOptions="{OnPlatform Android=End}">
        <Border Stroke="Transparent"
                Background="{StaticResource TanGradient}"
                StrokeShape="RoundRectangle 8"
                Padding="16"
                VerticalOptions="End">

            <Grid RowDefinitions="Auto,*"
                  RowSpacing="12">

                <outline:OutlinedLabel Grid.Row="0"
                                       Text="New Thread"
                                       FontFamily="PoppinsBold"
                                       FontSize="20"
                                       TextColor="#2E4A0F"
                                       HasShadow="True"
                                       ShadowColor="#29000040"
                                       ShadowBlur="2"
                                       ShadowOffsetY="2"/>

                <Grid Grid.Row="1"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="10">

                    <!-- Icon Picker Label + Preview -->
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Choose an icon"
                               FontFamily="PoppinsSemiBold"
                               FontSize="12"
                               TextColor="#2E4A0F"
                               Opacity="0.7"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="{Binding SelectedIcon}"
                               FontSize="28"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Icon Picker Row -->
                    <ScrollView Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding AvailableIcons}"
                                               Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="{x:Type x:String}">
                                    <Border StrokeShape="RoundRectangle 8"
                                            BackgroundColor="#EDF8EA"
                                            Stroke="#32000040"
                                            StrokeThickness="1.5"
                                            WidthRequest="48"
                                            HeightRequest="48">
                                        <Border.Behaviors>
                                            <toolkit:TouchBehavior DefaultAnimationDuration="120"
                                                                   DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                                                                   PressedOpacity="0.6"
                                                                   PressedScale="0.88"/>
                                        </Border.Behaviors>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NewGuildThreadSheetViewModel}}, Path=SelectIconCommand}"
                                                                  CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding .}"
                                               FontSize="26"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- Subject Entry -->
                    <Border Grid.Row="2"
                            BackgroundColor="#EDF8EA"
                            Stroke="#32000040"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="8,4">
                        <Entry Text="{Binding Subject}"
                               Placeholder="Thread subject..."
                               PlaceholderColor="#80000000"
                               TextColor="#1A1A1A"
                               FontFamily="Poppins"
                               FontSize="14"
                               BackgroundColor="Transparent"
                               MaxLength="80"
                               ReturnType="Done"
                               ReturnCommand="{Binding SubmitCommand}"/>
                    </Border>

                    <!-- Character count -->
                    <Label Grid.Row="3"
                           Text="{Binding Subject.Length, StringFormat='{0}/80'}"
                           FontFamily="Poppins"
                           FontSize="10"
                           TextColor="#80000000"
                           HorizontalOptions="End"/>

                    <!-- Error Message -->
                    <Label Grid.Row="4"
                           Text="{Binding ErrorMessage}"
                           FontFamily="Poppins"
                           FontSize="12"
                           TextColor="#C0442C"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                           HorizontalOptions="Center"/>

                    <!-- Create Button -->
                    <Border Grid.Row="5"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="0.2"
                            Stroke="Black"
                            Background="{StaticResource GradientRewards}"
                            Padding="15">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding CanSubmit}"
                                         Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.Behaviors>
                            <toolkit:TouchBehavior DefaultAnimationDuration="150"
                                                   DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                                                   PressedOpacity="0.6"
                                                   PressedScale="0.95"/>
                        </Border.Behaviors>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SubmitCommand}"/>
                        </Border.GestureRecognizers>
                        <outline:OutlinedLabel TextColor="#EDF8EA"
                                               Text="Create Thread"
                                               HorizontalOptions="Center"
                                               FontFamily="PoppinsSemiBold"
                                               FontSize="14"
                                               StrokeColor="#40000000"
                                               StrokeWidth="2"
                                               HasShadow="True"
                                               ShadowColor="#4D000000"
                                               ShadowBlur="1"
                                               ShadowOffsetY="1"/>
                    </Border>

                </Grid>
            </Grid>
        </Border>
    </Grid>

</the49:BottomSheet>
