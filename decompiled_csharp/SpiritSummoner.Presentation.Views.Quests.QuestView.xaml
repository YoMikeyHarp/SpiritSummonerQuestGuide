<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SpiritSummoner.Presentation.ViewModels.Quests"
             xmlns:models="clr-namespace:SpiritSummoner.Domain.Entities.Quests"
             xmlns:shared="clr-namespace:SpiritSummoner.Presentation.Views.Shared"
             xmlns:spiritcontrol="clr-namespace:SpiritSummoner.Presentation.Views.Spirits.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:outline="clr-namespace:SpiritSummoner.Presentation.ViewModels.Shared"
             xmlns:cnv="clr-namespace:SpiritSummoner.Presentation.Converters"
             x:Class="SpiritSummoner.Presentation.Views.Quests.QuestView"
             x:DataType="vm:QuestViewModel">

    <ContentView.Resources>
        <cnv:ShopItemSelectConverter x:Key="ShopItemSelectConverter"/>
        <cnv:AreaUnlockedConverter x:Key="AreaUnlockedConverter"/>
        <cnv:AreaLockedConverter x:Key="AreaLockedConverter"/>

        <LinearGradientBrush x:Key="AreaSelectionBackground"
                StartPoint="0.5,0"
                EndPoint="0.5,1">
            <GradientStop Color="#F9F5C0"
                    Offset="0.0"/>
            <GradientStop Color="#F6F1A6"
                    Offset="0.5"/>
            <GradientStop Color="#D9D491"
                    Offset="1.0"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SpiritsButton"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <GradientStop Color="#FFB816"
                          Offset="0.0"/>
            <GradientStop Color="#FFAE00"
                          Offset="0.25"/>
            <GradientStop Color="#FFAE00"
                          Offset="0.75"/>
            <GradientStop Color="#FFB816"
                          Offset="1.0"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SpiritsForegroundButton"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <GradientStop Color="#FED571"
                          Offset="0.0"/>
            <GradientStop Color="#FEF093"
                          Offset="0.2548"/>
            <GradientStop Color="#FEF89D"
                          Offset="0.5"/>
            <GradientStop Color="#FEF093"
                          Offset="0.75"/>
            <GradientStop Color="#FED571"
                          Offset="1"/>
        </LinearGradientBrush>
    </ContentView.Resources>
    
    <!-- Main Content-->
        <Grid RowDefinitions="*,25"
              Padding="10"
              RowSpacing="15">

            <!-- Area Selection-->
            <Border Grid.Row="0"
                    Stroke="#40000000"
                    StrokeThickness="2"
                    Background="{StaticResource AreaSelectionBackground}"
                    StrokeShape="RoundRectangle 16"
                    Padding="5"
                    VerticalOptions="Fill">

                <Grid>

                    <!-- Loading Overlay -->
                    <Grid IsVisible="{Binding IsLoading}"
                        BackgroundColor="#80000000"
                        ZIndex="10">
                        <ActivityIndicator IsRunning="{Binding IsLoading}"
                                        Color="White"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"/>
                        <Label Text="Loading quests..."
                            TextColor="White"
                            FontFamily="PoppinsSemiBold"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            TranslationY="40"/>
                    </Grid>

                    <!-- Quest Area Selection -->
                    <Grid RowDefinitions="Auto, *"
                          IsVisible="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}">

                    <Grid Padding="10,5"
                        ColumnDefinitions="*,100"
                        Grid.Row="0">

                        <Label Grid.Column="0"
                               FontSize="Large"
                               FontFamily="PoppinsBold"
                               TextColor="#2E4A0F"
                               LineBreakMode="WordWrap"
                               HorizontalOptions="Start"
                               VerticalOptions="Center"
                               Text="Quest Areas">
                               <Label.Shadow>
                                    <Shadow Brush="#40000000"
                                            Radius="0.5"
                                            Opacity="0.3"
                                            Offset="0,1"/>
                               </Label.Shadow>
                        </Label>

                        <Border Grid.Column="1"
                                StrokeShape="RoundRectangle 4"
                                Background="{StaticResource SpiritsButton}"
                                Padding="5"
                                x:Name="test">
                            <Border.Behaviors>
                                <toolkit:TouchBehavior DefaultAnimationDuration="250"
                                                    DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                                                    PressedOpacity="0.7"
                                                    PressedScale="0.85"/>
                            </Border.Behaviors>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToFullCollectionCommand}"/>
                            </Border.GestureRecognizers>
                            <Grid>
                                <Border StrokeShape="RoundRectangle 4"
                                        Background="{StaticResource SpiritsForegroundButton}"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill"
                                        Padding="5">
                                    <outline:OutlinedLabel Text="SPIRITS"
                                                           HorizontalOptions="End"
                                                           TextColor="#976D0D"
                                                           FontFamily="PoppinsBold"
                                                           FontSize="14"
                                                           StrokeColor="#EDF8EA80"
                                                           StrokeWidth="2"
                                                           HasShadow="True"
                                                           ShadowBlur="1"
                                                           ShadowOffsetY="1"
                                                           ShadowColor="Black"/>
                                </Border>
                                <Image Source="icon_spirits_outlined.png"
                                    HeightRequest="30"
                                    HorizontalOptions="Start"/>

                            </Grid>


                        </Border>
                    </Grid>

                    <!-- Areas Inner Section Box -->
                        <Border Stroke="Black"
                                Grid.Row="1"
                                StrokeThickness=".5"
                                BackgroundColor="White"
                                StrokeShape="RoundRectangle 8"
                                Padding="5">
                            <!-- Quest Areas -->
                            <CollectionView ItemsSource="{Binding Areas}"
                                            VerticalOptions="Fill"
                                            VerticalScrollBarVisibility="Never"
                                            ItemSizingStrategy="MeasureAllItems"
                                            RemainingItemsThreshold="5"
                                            x:Name="AreasCollectionView">

                            <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical"
                                                    ItemSpacing="7"/>
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Area">
                                        <Border StrokeShape="RoundRectangle 8"
                                                HeightRequest="95"
                                                StrokeThickness="1.5"
                                            IsVisible="{Binding Id, 
                                                                  Converter={StaticResource AreaUnlockedConverter}, 
                                                                  ConverterParameter={x:Reference AreasCollectionView}}">
                                            <Border.Behaviors>
                                                <toolkit:TouchBehavior DefaultAnimationDuration="250"
                                                                        DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                                                                        PressedOpacity="0.85"
                                                                        PressedScale="0.95"/>
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding x:DataType='vm:QuestViewModel',Source={RelativeSource AncestorType={x:Type vm:QuestViewModel}}, Path=SelectAreaCommand}"
                                                                  CommandParameter="{Binding Id}"/>
                                            </Border.GestureRecognizers>
                                            <Border.Stroke>
                                                <SolidPaint Color="Black"
                                                            BackgroundColor="Gray"/>
                                            </Border.Stroke>
                                            <Grid>
                                                <Image Source="{Binding Image}"
                                                    Aspect="AspectFill"/>

                                            <!-- Locked Overlay -->
                                            <BoxView BackgroundColor="#AA000000"
                                                     IsVisible="{Binding Id, 
                                                                    Converter={StaticResource AreaLockedConverter}, 
                                                                    ConverterParameter={x:Reference AreasCollectionView}}"/>

                                            <!-- Lock Icon -->
                                            <Label Text="🔒"
                                                   FontSize="48"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   IsVisible="{Binding Id, 
                                                                  Converter={StaticResource AreaLockedConverter}, 
                                                                  ConverterParameter={x:Reference AreasCollectionView}}"/>

                                            <Label Text="{Binding Name}"
                                                   Padding="15,5"
                                                   FontSize="36"
                                                   TextColor="White"
                                                   FontFamily="Italiano"
                                                   HorizontalOptions="Start"
                                                   VerticalOptions="End">
                                                <Label.Shadow>
                                                    <Shadow Brush="Black"
                                                            Offset="1,1"
                                                            Radius="1"/>
                                                </Label.Shadow>
                                            </Label>

                                            <!-- Quest Exclamation Indicator -->
                                            <Image Source="icon_exclamation2.webp"
                                                   Aspect="AspectFit"
                                                   HeightRequest="55"
                                                   HorizontalOptions="End"
                                                   VerticalOptions="Center"
                                                   Margin="10"
                                                   IsVisible="{Binding HasUnclaimedQuest}"/>
                                        </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>

                            <!-- Empty State -->
                            <CollectionView.EmptyView>
                                <VerticalStackLayout HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     Spacing="16"
                                                     Padding="40">
                                    <Label Text="📋"
                                           FontSize="48"
                                           HorizontalOptions="Center"/>
                                    <Label Text="No quests available"
                                           FontFamily="PoppinsSemiBold"
                                           FontSize="Medium"
                                           TextColor="Gray"
                                           HorizontalOptions="Center"/>
                                    <Label Text="Complete previous quests or check back later"
                                           FontFamily="PoppinsSemiBold"
                                           FontSize="Small"
                                           TextColor="Gray"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                        </CollectionView>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Stroke="Black"
                    BackgroundColor="Transparent"
                    StrokeThickness="0.5"
                    StrokeShape="RoundRectangle 2">
                <Grid ColumnDefinitions="*,*,*"
                    ColumnSpacing="0"
                    HorizontalOptions="Fill">
                    <!-- Story Tab -->
                    <Border Grid.Column="0"
                            Background="{Binding CurrentQuestType,Converter={StaticResource ShopItemSelectConverter},ConverterParameter='story'}"
                            VerticalOptions="Fill">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectQuestTypeCommand}"
                                                CommandParameter="story"/>
                        </Border.GestureRecognizers>

                        <outline:OutlinedLabel Text="Story"
                                           FontSize="12"
                                           FontFamily="PoppinsSemiBold"
                                           TextColor="#FFFFFF"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"
                                           StrokeColor="#40000000"
                                           StrokeWidth="2"
                                           HasShadow="False"/>
                    </Border>

                    <!-- Challenge Tab -->
                    <Border Grid.Column="1"
                            Background="{Binding CurrentQuestType,Converter={StaticResource ShopItemSelectConverter},ConverterParameter='challenge'}"
                            VerticalOptions="Fill">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectQuestTypeCommand}"
                                                CommandParameter="challenge"/>
                        </Border.GestureRecognizers>

                    <outline:OutlinedLabel Text="Challenge"
                                           FontSize="12"
                                           FontFamily="PoppinsSemiBold"
                                           TextColor="#FFFFFF"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"
                                           StrokeColor="#40000000"
                                           StrokeWidth="2"
                                           HasShadow="False"/>
                </Border>

                    <!-- Events Tab -->
                    <Border Grid.Column="2"
                            Background="{Binding CurrentQuestType,Converter={StaticResource ShopItemSelectConverter},ConverterParameter='dojo'}"
                            VerticalOptions="Fill">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectQuestTypeCommand}"
                                                CommandParameter="dojo"/>
                        </Border.GestureRecognizers>

                    <outline:OutlinedLabel Text="Dojo"
                                           FontSize="12"
                                           FontFamily="PoppinsSemiBold"
                                           TextColor="#FFFFFF"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"
                                           StrokeColor="#40000000"
                                           StrokeWidth="2"
                                           HasShadow="False"/>
                </Border>

                    <!-- Vertical Separators -->
                    <BoxView Grid.Column="0"
                            BackgroundColor="Black"
                            WidthRequest="1"
                            Opacity="0.5"
                            HorizontalOptions="End"
                            VerticalOptions="Fill"/>
                    <BoxView Grid.Column="1"
                            BackgroundColor="Black"
                            WidthRequest="1"
                            Opacity="0.5"
                            HorizontalOptions="End"
                            VerticalOptions="Fill"/>
                </Grid>
            </Border>

    </Grid>
</ContentView>