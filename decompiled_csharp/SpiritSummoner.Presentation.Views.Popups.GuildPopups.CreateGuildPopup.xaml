<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:vm="clr-namespace:SpiritSummoner.Presentation.ViewModels.Popups"
               x:Class="SpiritSummoner.Presentation.Views.Popups.GuildPopups.CreateGuildPopup"
               x:DataType="vm:CreateGuildPopupViewModel"
               Size="375,625"
               Color="Transparent">

    <Border Padding="5" 
            Background="{StaticResource GradientBackground}"
            StrokeShape="RoundRectangle 8">

        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="5">

            <!-- Title -->
            <Label  Grid.Row="0"
                    Text="Create Your Own Guild!" 
                    TextColor="Black"
                    FontSize="Medium" 
                    FontFamily="Poppins"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    IsVisible="{Binding IsEditingMode,Converter={StaticResource InverseBooleanConverter}}"/>
            <Label  Grid.Row="0"
                    Text="Edit Your Guild!" 
                    TextColor="Black"
                    FontSize="Medium" 
                    FontFamily="Poppins"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    IsVisible="{Binding IsEditingMode}"/>
            


            <Border Grid.Row="1"
                    Padding="20" 
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Background="{StaticResource GradientBackgroundSpirit}">

                <VerticalStackLayout Spacing="10">

                    <HorizontalStackLayout Spacing="5">
                        <Label Text="Guild Name" TextColor="Black" FontSize="12" FontAttributes="Bold" VerticalTextAlignment="Center" />
                        
                        <Entry Text="{Binding GuildName}" 
                            Placeholder="Enter guild name (3-20 characters)"
                            MaxLength="20"
                            PlaceholderColor="Gray"/>

                    </HorizontalStackLayout>
                    
                    
                    <!-- Seperator -->
                    <BoxView HeightRequest="1" Color="DimGray" Opacity="0.5"/>

                    <!-- Emblem Selection -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Select Emblem" FontSize="12" FontAttributes="Bold" />
                        <CollectionView ItemsSource="{Binding AvailableEmblems}"
                                        HeightRequest="60"
                                        SelectionMode="Single"
                                        SelectedItem="{Binding SelectedEmblem, Mode=TwoWay}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Border WidthRequest="50"
                                        HeightRequest="50"
                                        StrokeShape="RoundRectangle 10"
                                        Padding="0"
                                        Stroke="Transparent"
                                        BackgroundColor="Transparent">

                                        <Label Text="{Binding .}"
                                               FontSize="30"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding x:DataType='vm:CreateGuildPopupViewModel', Source={RelativeSource AncestorType={x:Type vm:CreateGuildPopupViewModel}}, Path=SelectEmblemCommand}"
                                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="DimGray" Opacity="0.5"/>

                    
                    <!-- Description -->
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">

                        <Label Grid.Column="0"
                               Padding="5"
                               Text="Description" 
                               TextColor="Black"
                               FontSize="12"
                               FontAttributes="Bold" 
                               VerticalTextAlignment="Start"/>
                        
                        <Border Grid.Column="1"
                                Padding="5"
                                Stroke="Transparent"
                                BackgroundColor="White"
                                StrokeShape="RoundRectangle 8">
                            <Editor  
                                Text="{Binding Description}" 
                                Placeholder="Describe your guild..."
                                PlaceholderColor="Gray"
                                TextColor="Black"
                                MaxLength="200"
                                HeightRequest="100"/>
                        </Border>
                    </Grid>

                    <BoxView HeightRequest="1" Color="DimGray" Opacity="0.5"/>

                    
                    <!-- Guild Type -->
                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding IsPublic}" />
                        <Label Text="Viewable to all players" TextColor="Black" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    
                    <!-- Requires Approval -->
                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding InstantJoin}" />
                        <Label Text="Instant join"  TextColor="Black" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Required Trophies -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Required Trophies" FontSize="12" FontAttributes="Bold" />

                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="🏆" FontSize="18" HorizontalOptions="Center" />

                            <Label Text="{Binding MinTrophiesRequired, StringFormat='{0:N0}'}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#FF6B35"
                                   VerticalTextAlignment="Center"/>
                        </HorizontalStackLayout>

                        <Slider Value="{Binding MinTrophiesRequired, Mode=TwoWay}"
                                Minimum="0"
                                Maximum="10000"
                                MinimumTrackColor="#4CAF50"
                                MaximumTrackColor="#E0E0E0"
                                ThumbColor="#2E7D32"/>
                    </VerticalStackLayout>

                    <!-- Required Level -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Required Level" FontSize="12" FontAttributes="Bold" />

                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="LvL" FontSize="18" HorizontalOptions="Center" />

                            <Label Text="{Binding MinLevelRequired, StringFormat='{0:N0}'}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#FF6B35"
                                   VerticalTextAlignment="Center"/>
                        </HorizontalStackLayout>

                        <Slider Value="{Binding MinLevelRequired, Mode=TwoWay}"
                                Minimum="0"
                                Maximum="100"
                                MinimumTrackColor="#4CAF50"
                                MaximumTrackColor="#E0E0E0"
                                ThumbColor="#2E7D32"/>
                    </VerticalStackLayout>
                    
                    <!-- Error Message -->
                    <Label Text="{Binding ErrorMessage}" 
                        TextColor="Red"
                        IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}" />
                    
                </VerticalStackLayout>
            </Border>

            <!-- Create Button -->
            <Button Text="CREATE GUILD"
                    Grid.Row="2"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    Background="{StaticResource GoldGradient}"
                    TextColor="Black"
                    FontFamily="PoppinsExtraBold"
                    Command="{Binding CreateGuildCommand}"
                    IsEnabled="{Binding CanCreate}"
                    IsVisible="{Binding IsEditingMode,Converter={StaticResource InverseBooleanConverter}}" />

            <!-- Edit Button -->
            <Button Text="EDIT GUILD"
                    Grid.Row="2"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    Background="{StaticResource GoldGradient}"
                    TextColor="Black"
                    FontFamily="PoppinsExtraBold"
                    Command="{Binding EditGuildCommand}"
                    IsEnabled="{Binding IsEditingMode}"
                    IsVisible="{Binding IsEditingMode}" />

        </Grid>

    </Border>
    
</toolkit:Popup>