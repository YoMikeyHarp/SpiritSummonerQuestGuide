<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:SpiritSummoner.Presentation.ViewModels.StartUp"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:converters="clr-namespace:SpiritSummoner.Presentation.Converters"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:outline="clr-namespace:SpiritSummoner.Presentation.ViewModels.Shared"
             x:Class="SpiritSummoner.Presentation.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             ios:Page.UseSafeArea="True"
             Background="{StaticResource GradientBackground}"
             xmlns:shell="clr-namespace:Microsoft.Maui.Controls;assembly=Microsoft.Maui.Controls"
             shell:Shell.NavBarIsVisible="False">

    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="Black"
                                   StatusBarStyle="Default"/>
    </ContentPage.Behaviors>

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />

            <!-- Button Style -->
            <Style x:Key="SpiritSummonerButtonStyle" TargetType="Button">
                <Setter Property="CornerRadius" Value="24" />
                <Setter Property="BackgroundColor" Value="#C03D3D" />
                <Setter Property="TextColor" Value="#FFFFFF" />
                <Setter Property="FontFamily" Value="PoppinsSemiBold" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="Padding" Value="20,10" />
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="#66000000"
                                Offset="1,1"
                                Radius="4"
                                Opacity="0.8" />
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>

        <Grid>

            <Image Source="splash_loading.png"
                   Aspect="AspectFit"
                   IsVisible="false"/>

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="Black"
                               HeightRequest="60"
                               WidthRequest="60"
                               VerticalOptions="End"
                               HorizontalOptions="Center"/>

            <Grid IsVisible="true"
                  Padding="20"
                  RowDefinitions="*,Auto">

                <Image Source="dots_offset_8px.png" Scale="1.2"/>

                <ImageButton BackgroundColor="Transparent" Source="icon_back_outlined.png" HeightRequest="10" Scale="1.5" WidthRequest="30" Margin="15" VerticalOptions="Start" HorizontalOptions="Start"
                        Command="{Binding GoBackToWelcomeCommand}" IsVisible="false"/>

                <!-- Username Selection Mode (during Begin Journey registration) -->
                <Grid RowDefinitions="Auto,Auto,Auto" IsVisible="{Binding IsUsernameSelectionMode}" VerticalOptions="Center" RowSpacing="20">

                    <VerticalStackLayout Grid.Row="0" Spacing="5" Padding="20">
                        <Image Source="friendsicon.png"
                               HeightRequest="100"
                               HorizontalOptions="Center"
                               IsVisible="True"/>

                        <Label Text="Choose Summoner ID"
                               FontFamily="PoppinsSemiBold"
                               HorizontalTextAlignment="Center"
                               FontSize="20"/>

                        <Label Text="Claim a unique username to be displayed as your Summoner ID."
                               FontFamily="PoppinsMedium"
                               HorizontalTextAlignment="Center"
                               FontSize="16"
                               TextColor="#78343434"
                               Grid.Column="0"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="1" Spacing="15" Padding="20,0">
                        <!-- Username Field -->
                        <VerticalStackLayout Spacing="4">
                            <Grid ColumnDefinitions="*,Auto"
                                  Padding="0">
                                <Label Text="Username"
                                       FontFamily="PoppinsSemiBold"
                                       FontSize="Small"
                                       TextColor="Black"
                                       Grid.Column="0"/>
                            </Grid>
                            <Border StrokeShape="RoundRectangle 10"
                                    HeightRequest="50">
                                <Grid ColumnDefinitions="Auto,*"
                                      BackgroundColor="#FFFFFF"
                                      Padding="10,5"
                                      ColumnSpacing="10">
                                    <Image Source="{mi:FontAwesomeSolid Icon=Pen, IconColor=#888}"
                                           WidthRequest="15.41"
                                           HeightRequest="15.41"
                                           Grid.Column="0"/>
                                    <Entry Placeholder="SpiritSummonerMaster71"
                                           Text="{Binding Username}"
                                           TextColor="Black"
                                           FontSize="12"
                                           FontFamily="PoppinsMedium"
                                           PlaceholderColor="#97000000"
                                           Grid.Column="1"
                                           HorizontalOptions="Fill"/>
                                </Grid>
                            </Border>

                        </VerticalStackLayout>

                        <!-- Confirm Username Field -->
                        <VerticalStackLayout Spacing="4">
                            <Grid ColumnDefinitions="*,Auto"
                                  Padding="0">
                                <Label Text="Confirm Username"
                                       FontFamily="PoppinsSemiBold"
                                       FontAttributes="Bold"
                                       FontSize="14"
                                       TextColor="Black"
                                       Grid.Column="0"/>
                            </Grid>
                            <Border StrokeShape="RoundRectangle 10">
                                <Grid ColumnDefinitions="Auto,*"
                                      BackgroundColor="#FFFFFF"
                                      Padding="10,5"
                                      ColumnSpacing="10"
                                      HeightRequest="50">
                                    <Image Source="{mi:FontAwesomeSolid Icon=Pen, IconColor=Gray}"
                                           WidthRequest="16"
                                           HeightRequest="16"
                                           Grid.Column="0"/>
                                    <Entry TextColor="Black"
                                           Placeholder="SpiritSummonerMaster71"
                                           Text="{Binding VerifyUsername}"
                                           Grid.Column="1"
                                           FontFamily="PoppinsMedium"
                                           FontSize="12"
                                           PlaceholderColor="#97000000"
                                           HorizontalOptions="Fill"/>
                                </Grid>
                            </Border>

                        </VerticalStackLayout>

                        <Label HorizontalTextAlignment="Center"
                               FontSize="14"
                               Grid.Column="0">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="NOTE: "
                                          FontFamily="PoppinsBold"
                                          TextColor="#97000000"/>
                                    <Span Text="Your username can only be changed later with the user of premium currency."
                                          FontFamily="PoppinsMedium"
                                          TextColor="#97000000"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <!-- Confirm Username Button -->
                        <Border StrokeShape="RoundRectangle 8"
                                Background="{StaticResource GradientRewards}"
                                HeightRequest="40"
                                WidthRequest="250">
                            <Border.Shadow>
                                <Shadow Brush="Transparent"
                                        Offset="0,1.5"
                                        Radius="2"/>
                            </Border.Shadow>
                            <Border.Behaviors>
                                <toolkit:TouchBehavior DefaultAnimationDuration="250"
                                                       DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                                                       PressedOpacity="0.7"
                                                       PressedScale="0.85"/>
                            </Border.Behaviors>
                            <Grid>
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ConfirmUsernameCommand}"/>
                                </Grid.GestureRecognizers>
                                <outline:OutlinedLabel Text="Confirm"
                                                       TextColor="#EDF8EA"
                                                       FontFamily="PoppinsSemiBold"
                                                       HeightRequest="50"
                                                       StrokeColor="#5200004D"
                                                       StrokeWidth="2"
                                                       HasShadow="True"
                                                       ShadowColor="#5200004D"
                                                       ShadowBlur="1"
                                                       ShadowOffsetY="1"/>

                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="2"
                            Padding="0,0,0,0">
                        <Label Text="Please do not user profanity, hate speach, or personally identifiable information (i.e. real name, address, etc.)."
                               FontFamily="Poppins"
                               HorizontalTextAlignment="Center"
                               FontSize="12"
                               TextColor="#97000000"
                               Grid.Column="0"/>

                        <Label Text="Improper user of usernames can result in a ban"
                               FontFamily="PoppinsBold"
                               HorizontalTextAlignment="Center"
                               FontSize="12"
                               Padding="0,10"
                               TextColor="#97000000"
                               Grid.Column="0"/>

                        <Label Text="For more information, please refer to the Code of Conduct."
                               FontFamily="Poppins"
                               HorizontalTextAlignment="Center"
                               FontSize="12"
                               TextColor="#97000000"
                               Grid.Column="0"/>
                    </VerticalStackLayout>

                </Grid>

                <!-- Sign In Mode -->
                <VerticalStackLayout Spacing="20"
                                     Padding="30"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Fill"
                                     IsVisible="{Binding IsUsernameSelectionMode, Converter={StaticResource InverseBooleanConverter}}">

                    <VerticalStackLayout Spacing="10">
                        <Image Source="icon_crystal.png"
                               HeightRequest="120"
                               HorizontalOptions="Center"/>

                        <Label Text="Login to your account"
                               FontFamily="PoppinsSemiBold"
                               FontSize="20"
                               HorizontalOptions="Center"
                               TextColor="#000000"/>

                        <Label Text="Enter your details to login."
                               FontFamily="PoppinsMedium"
                               FontSize="14"
                               HorizontalOptions="Center"
                               TextColor="#5A000013"/>

                        <!-- Social Login Buttons -->
                        <HorizontalStackLayout Spacing="10"
                                               HorizontalOptions="Center">
                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#DDD"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 10"
                                    WidthRequest="150"
                                    HeightRequest="40">
                                <Border.Behaviors>
                                    <toolkit:TouchBehavior
                                        DefaultAnimationDuration="250"
                                        DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                                        PressedOpacity="0.6"
                                        PressedScale="0.7"/>
                                </Border.Behaviors>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SignInWithGoogleCommand}"/>
                                </Border.GestureRecognizers>
                                <Image Source="logo_google.png"
                                       HeightRequest="20"
                                       HorizontalOptions="Center"/>
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#DDD"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 10"
                                    WidthRequest="150"
                                    HeightRequest="40"
                                    IsEnabled="False"
                                    IsVisible="{ OnPlatform Android=false, iOS=True}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SignInWithAppleCommand}"/>
                                </Border.GestureRecognizers>
                                <Border.Behaviors>
                                    <toolkit:TouchBehavior
                                        DefaultAnimationDuration="250"
                                        DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                                        PressedOpacity="0.6"
                                        PressedScale="0.7"/>
                                </Border.Behaviors>
                                <Image Source="logo_apple.png"
                                       HeightRequest="24"
                                       HorizontalOptions="Center"/>
                            </Border>

                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#DDD"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 10"
                                    WidthRequest="150"
                                    HeightRequest="40">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SignInWithFacebookCommand}"/>
                                </Border.GestureRecognizers>
                                <Border.Behaviors>
                                    <toolkit:TouchBehavior
                                        DefaultAnimationDuration="250"
                                        DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                                        PressedOpacity="0.6"
                                        PressedScale="0.7"/>
                                </Border.Behaviors>
                                <Image Source="logo_facebook.png"
                                       HeightRequest="24"
                                       HorizontalOptions="Center"/>
                            </Border>
                        </HorizontalStackLayout>

                        <!-- OR Divider -->
                        <HorizontalStackLayout Spacing="10"
                                               VerticalOptions="Center"
                                               HorizontalOptions="Center">
                            <BoxView HeightRequest="1"
                                     WidthRequest="135"
                                     Color="#888"
                                     VerticalOptions="Center"/>
                            <Label Text="OR"
                                   FontSize="16"
                                   FontFamily="PoppinsMedium"
                                   TextColor="#000000"/>
                            <BoxView HeightRequest="1"
                                     WidthRequest="135"
                                     Color="#888"
                                     VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>

                    <!-- Username / Email Field -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Email Address"
                               FontFamily="PoppinsSemiBold"
                               FontSize="14"
                               TextColor="#000000"/>
                        <Border BackgroundColor="#FFFFFF"
                                StrokeShape="RoundRectangle 10"
                                Padding="5"
                                HeightRequest="50">
                            <Grid ColumnDefinitions="Auto,*"
                                    ColumnSpacing="10">
                                <Image Source="mage_email.png"
                                       WidthRequest="16"
                                       Grid.Column="0"
                                       HeightRequest="16"/>
                                <Entry Placeholder="Username / email@summoner.com"
                                       Text="{Binding Username}"
                                       Keyboard="Email"
                                       TextColor="Black"
                                       FontFamily="PoppinsBold"
                                       FontSize="12"
                                       Grid.Column="1"
                                       HorizontalOptions="Fill"
                                       PlaceholderColor="#888"/>
                            </Grid>

                        </Border>
                    </VerticalStackLayout>

                    <!-- Password Field -->
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="0">
                            <Label Text="Password"
                                   FontFamily="PoppinsSemiBold"
                                   FontSize="Small"
                                   TextColor="Black"
                                   Grid.Column="0"/>
                            <Label Text="Forgot password?"
                                   FontFamily="PoppinsMedium"
                                   FontSize="12"
                                   TextColor="#000000"
                                   TextDecorations="Underline"
                                   Grid.Column="1"/>
                        </Grid>
                        <Border StrokeShape="RoundRectangle 10"
                                HeightRequest="50">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  BackgroundColor="#FFFFFF"
                                  Padding="5"
                                  ColumnSpacing="10">
                                <Image Source="icon_lock_outline.png"
                                       WidthRequest="16"
                                       HeightRequest="16"
                                       Grid.Column="0"/>
                                <Entry IsPassword="{Binding IsPasswordVisible}"
                                       Placeholder="***********"
                                       FontSize="12"
                                       FontFamily="PoppinsMedium"
                                       Text="{Binding Password}"
                                       TextColor="Black"
                                       PlaceholderColor="#888"
                                       Grid.Column="1"
                                       HorizontalOptions="Fill"/>
                                <Image Source="icon_eye_outline.png"
                                       WidthRequest="16"
                                       HeightRequest="16"
                                       Grid.Column="2">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}"/>
                                    </Image.GestureRecognizers>
                                </Image>
                            </Grid>
                        </Border>

                    </VerticalStackLayout>

                    <!-- Login Button -->
                    <Border StrokeShape="RoundRectangle 8"
                            Background="{StaticResource GradientRewards}"
                            HeightRequest="40"
                            WidthRequest="250">
                        <Border.Shadow>
                            <Shadow Brush="Transparent"
                                    Offset="0,2"
                                    Radius="4"/>
                        </Border.Shadow>
                        <Border.Behaviors>
                            <toolkit:TouchBehavior DefaultAnimationDuration="250"
                                                   DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                                                   PressedOpacity="0.7"
                                                   PressedScale="0.85"/>
                        </Border.Behaviors>
                        <Grid>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SignInCommand}"/>
                            </Grid.GestureRecognizers>
                            <outline:OutlinedLabel Text="Login"
                                                   TextColor="#EDF8EA"
                                                   FontFamily="PoppinsSemiBold"
                                                   IsVisible="true"
                                                   HeightRequest="50"
                                                   StrokeColor="#5200004D"
                                                   StrokeWidth="2"
                                                   HasShadow="True"
                                                   ShadowColor="#5200004D"
                                                   ShadowBlur="1"
                                                   ShadowOffsetY="1"/>

                        </Grid>
                    </Border>

                    <!-- Register Link -->
                    <HorizontalStackLayout HorizontalOptions="Center"
                                           Spacing="4">
                        <Label Text="Don't have an account?"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="Black"/>
                        <Label Text="Start fresh!"
                               FontFamily="PoppinsBold"
                               FontSize="13"
                               TextColor="Black"
                               TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoBackToWelcomeCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                    <!-- Footer -->
                    <Label Text="©2025 Spirit Summoner     ©2025 Summoner Co., LLC"
                           FontSize="12"
                           FontFamily="PoppinsMedium"
                           TextColor="#38000080"
                           HorizontalOptions="Center"
                           Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Grid>

        </Grid>

    </ScrollView>

</ContentPage>
